# --- REALM ARCHITECTURE ---

# Global State Map: Defines every possible transition to prevent glitches.

WORLD_DATA = {

"root": {

"title": "Beneath the Immortal Peach Tree",

"desc": "You are Leela. A single peach blossom hangs in the air, refusing to fall.\n"

"To the north: Evergreen Dawn. To the west: Jade Summit. To the east: River of Echoes.\n"

"Above and within: The Infinite Library.",

"paths": {"evergreen": "evergreen", "jade": "jade", "river": "river", "library": "lib_gate"}

},

"evergreen": {

"title": "The Evergreen Dawn",

"desc": "The scent of pine and crushed blossoms fills the cool air.\n"

"The Memory Forest stretches deep here. Every tree is a story.",

"paths": {"bench": "evergreen_bench", "back": "root"}

},

"evergreen_bench": {

"title": "The Bench of Remembering",

"desc": "A stone bench carved with ancient glyphs. Sitting here, you feel\n"

"the weight of lives you haven't lived yet.",

"paths": {"back": "evergreen"}

},

"jade": {

"title": "The Jade Summit",

"desc": "The air is thin and crystalline. Hexagrams shift in the clouds.\n"

"This is the realm of sharp decisions and high thresholds.",

"paths": {"cliff": "jade_cliff", "back": "root"}

},

"jade_cliff": {

