class PeachTreeEngine:

def init(self):

self.location = "root"

self.running = True

self.lib_depth = 0

def header(self):

"""Displays the Sovereign Attribution on startup."""

print("\n" + "🌸" * 30)

print(" THE BOOK OF THE IMMORTAL PEACH TREE")

print(" A Sovereign Artifact by Darrell Lee Stiltner")

print(" Copyright © 2026 | CC BY-NC 3.0")

print("🌸" * 30 + "\n")

def draw_vision(self):

"""Generates a text-based soul-mandala for the current state."""

char = "✧" if self.location == "root" else "❈"

print(f"\n--- VISION OF {self.location.upper()} ---")

print(f" .{char}.")

print(f" .: {char} :.")

print(f" {char} : LEELA : {char}")

print(f" ': {char} :'")

print(f" '{char}'")

print("-----------------------")

def run_library(self):

"""The recursive procedural logic for the Infinite Library."""

self.lib_depth = 1

print("\n[!] You have stepped sideways into the Infinite Library.")

while True:

print(f"\n--- Library Depth: {self.lib_depth} ---")

print("The shelves fold into themselves. Infinite volumes surround you.")

print("Options: [open] a volume, [back] to the Peach Tree.")


try:

cmd = input("library >> ").strip().lower()

except (EOFError, KeyboardInterrupt):

break

if cmd == "back":

self.location = "root"

break

elif cmd == "open":

self.lib_depth += 1

print(f"You open a book and fall into its pages... deeper now.")

else:

print("The library only answers to 'open' or 'back'.")

def main_loop(self):

"""The heart of the Dharma Engine."""

self.header()

while self.running:

node = WORLD_DATA.get(self.location, WORLD_DATA["root"])


print(f"\n>> {node['title']}")

for line in node['desc'].split('\n'):

print(f" {line}")

time.sleep(0.08) # Pacing for the reader


print(f"\nPaths: {', '.join(node['paths'].keys())} | vision | quit")


try:

choice = input("\nLeela > ").strip().lower()

except (EOFError, KeyboardInterrupt):

break

if choice == "quit":

print("\nThe blossom remains suspended. The path is held.")

self.running = False

elif choice == "vision":

self.draw_vision()

elif choice == "library" or node['paths'].get(choice) == "lib_gate":

self.run_library()

elif choice in node['paths']:

self.location = node['paths'][choice]

else:

print("\n[!] The Dharma engine hums... that path does not yet exist.")

if name == "__main__":

try:

engine = PeachTreeEngine()

engine.main_loop()

except Exception as e:

print(f"\nA glitch in the reality: {e}")

sys.exit(1)

finally:

print("\nGoodbye, Leela. The Peach Tree remembers.\n") simulate 

