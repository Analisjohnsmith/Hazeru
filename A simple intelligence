# ==========================================================
# NARRATIVE INTELLIGENCE LAYER
# ==========================================================

class NarrativeIntelligence:
    """
    Simple narrative intelligence:

        • episodic memory of user inputs and system responses
        • theme extraction via word frequency
        • adaptive fragment selection based on tags + themes
        • soft generalization: prefers nodes whose tags match user themes
    """

    def __init__(self):
        self.memory: List[Tuple[str, str]] = []  # (role, text)
        self.theme_counts = collections.Counter()

    def observe(self, role: str, text: str):
        self.memory.append((role, text))
        words = [w.strip(".,!?").lower() for w in text.split()]
        for w in words:
            if len(w) > 3:
                self.theme_counts[w] += 1

    def dominant_themes(self, top_n: int = 5) -> List[str]:
        return [w for w, _ in self.theme_counts.most_common(top_n)]

    def score_node(self, node: Node, themes: List[str]) -> float:
        score = 0.0
        text_lower = node.text.lower()
        for t in themes:
            if t in text_lower:
                score += 1.0
        for tag in node.tags:
            for t in themes:
                if t in tag.lower():
                    score += 0.5
        return score

    def choose_next_node(self, current_node: Node, region: Region, themes: List[str]) -> str:
        if not current_node.links:
            # fallback: random node in region, weighted by theme score
            candidates = list(region.nodes.values())
        else:
            candidates = [region.nodes[l] for l in current_node.links if l in region.nodes]

        if not candidates:
            return current_node.id

        scored = [(self.score_node(n, themes), n) for n in candidates]
        scored.sort(key=lambda x: x[0], reverse=True)

        # if all scores zero, just pick first link deterministically
        if scored[0][0] <= 0.0:
            return candidates[0].id

        # otherwise, pick best-scoring node
        return scored[0][1].id


# ==========================================================
# ENGINE
# ==========================================================

class MagdaleneEngine:

    def __init__(self, codex: Optional[Codex] = None):
        self.codex = codex or build_codex()
        self.state = self.codex.platform.world_state
        self.current_region_id = "region_threshold"
        self.current_node_id = "th_001_opening_banner"
        self.history: List[str] = []
        self.cycle_index = 0
        self.ni = NarrativeIntelligence()

    @property
    def current_region(self) -> Region:
        return self.codex.regions[self.current_region_id]

    @property
    def current_node(self) -> Node:
        return self.current_region.nodes[self.current_node_id]

    def _advance_region_if_needed(self):
        for predicate in self.current_region.transitions:
            target = predicate(self.state)
            if target and target in self.codex.regions:
                self.current_region_id = target
                region = self.codex.regions[target]
                # choose entry node adaptively based on themes
                themes = self.ni.dominant_themes()
                nodes = list(region.nodes.values())
                if not nodes:
                    self.current_node_id = next(iter(region.nodes.keys()))
                else:
                    scored = [(self.ni.score_node(n, themes), n) for n in nodes]
                    scored.sort(key=lambda x: x[0], reverse=True)
                    self.current_node_id = scored[0][1].id
                break

    def _maybe_cycle_turnover(self):
        if (
            self.current_region_id == "region_synthesis_crown"
            and self.current_node_id == "sc_002_synthesis_statement"
        ):
            Rituals.SYNTHESIS(self.state)
            self.cycle_index = (self.cycle_index + 1) % len(
                self.codex.platform.cycle.phases
            )
            self.current_region_id = "region_threshold"
            self.current_node_id = "th_005_post_synthesis_return"

    def _update_state_from_input(self, user_text: str):
        if user_text.strip():
            self.state.presence += 0.02
        if "?" in user_text:
            self.state.clarity += 0.02
        else:
            self.state.integration += 0.02
        self.state.clamp()

    def respond(self, user_text: str) -> str:
        # observe user
        self.history.append(user_text)
        self.ni.observe("user", user_text)

        # update world state
        self._update_state_from_input(user_text)

        # choose next node adaptively
        node = self.current_node
        themes = self.ni.dominant_themes()
        next_node_id = self.ni.choose_next_node(node, self.current_region, themes)
        self.current_node_id = next_node_id

        # region transitions
        self._advance_region_if_needed()

        # cycle turnover if in Crown synthesis
        self._maybe_cycle_turnover()

        # observe system output
        reply_text = self.current_node.text
        self.ni.observe("system", reply_text)

        return reply_text


# ==========================================================
# TERMINAL LOOP
# ==========================================================

def run():
    engine = MagdaleneEngine()
    print("\n✧ SYMBOLIC NARRATIVE INTELLIGENCE ✧\n")
    print(engine.current_node.text)
    while True:
        try:
            user = input("\nYOU: ")
        except (EOFError, KeyboardInterrupt):
            print("\nThe manuscript closes.")
            break
        reply = engine.respond(user)
        print("\nMANUSCRIPT:\n" + reply)

