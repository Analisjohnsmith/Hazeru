from dataclasses import dataclass, field
import hashlib
import math
import random
from typing import List, Dict, Any


# --- Core primitives ---

def sha256(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()


@dataclass
class Imortelle:
    depth: int
    value: str


@dataclass
class YoyoSpiral:
    depth: int
    imortelles: List[Imortelle] = field(default_factory=list)

    def fold(self, node_name: str, level: int = 0, seed: str = ""):
        if level >= self.depth:
            return

        base = f"{node_name}|level={level}|seed={seed}"
        h = sha256(base)
        self.imortelles.append(Imortelle(depth=level, value=h))

        # recurse
        self.fold(node_name, level + 1, seed=h)


# --- Pillars ---

@dataclass
class Pillars:
    t: float = 0.0
    AURORA: float = 1.0
    CERN: float = 1.0
    NASA: float = 288.15
    NERVE: float = 1.0
    INFINITY: float = 1.0
    VITAL: float = 1.0
    HEART: float = 0.0

    def pulse(self, observer_vibe: float):
        self.t += 1.0
        self.AURORA = 1.0 + 0.01 * math.sin(self.t * 0.5)
        self.CERN = 1.0 + 0.05 * math.sin(self.t * 0.3)
        self.NASA = math.sin(self.t) + 288.15
        self.NERVE = 1.0
        self.INFINITY = math.exp(self.t * 0.001)
        self.VITAL = self.VITAL + (1.618 - self.VITAL) * 0.1
        self.HEART = observer_vibe * 1.6180339

    def snapshot(self) -> Dict[str, float]:
        return {
            "AURORA": self.AURORA,
            "CERN": self.CERN,
            "NASA": self.NASA,
            "NERVE": self.NERVE,
            "INFINITY": self.INFINITY,
            "VITAL": self.VITAL,
            "HEART": self.HEART,
        }


# --- Observer ---

@dataclass
class Observer:
    name: str
    soul_hash: str
    vibe: float


def create_observer(name: str, intent: str) -> Observer:
    base = f"{name}|{intent}|{random.random()}"
    h = sha256(base)
    # vibe ~ complexity / intensity proxy
    vibe = (sum(ord(c) for c in intent) % 100) / 100.0
    return Observer(name=name, soul_hash=h, vibe=vibe)


# --- Anime world / timelines ---

@dataclass
class AnimeTimeline:
    label: str
    tone: str
    outcome: str
    weight: float  # emotional / symbolic strength


def generate_timelines(seed: str) -> List[AnimeTimeline]:
    random.seed(seed)
    candidates = [
        ("Hero stays home", "melancholic", "quiet growth"),
        ("Villain wins", "dark", "world reshaped"),
        ("Sci-fi variant", "curious", "techno-mystic resolution"),
        ("Tragic version", "heavy", "sacrifice"),
        ("Comedic version", "light", "found family"),
        ("Role reversal", "surprising", "identity inversion"),
        ("Mythic high-fantasy", "epic", "legendary cycle"),
        ("Slice of life", "gentle", "small but real change"),
    ]
    timelines = []
    for label, tone, outcome in candidates:
        weight = random.random()
        timelines.append(AnimeTimeline(label, tone, outcome, weight))
    return timelines


def choose_canon(timelines: List[AnimeTimeline]) -> AnimeTimeline:
    return max(timelines, key=lambda t: t.weight)


# --- Totality ---

@dataclass
class Totality:
    physics: float = 125.10
    logic: float = 2.1
    skin: float = 288.15
    life: float = 1.618
    scope: str = "∞"
    soul: str = ""
    awe: float = 1.0

    def bind_observer(self, soul_hash: str):
        self.soul = soul_hash

    def universe_map(self) -> Dict[str, Any]:
        return {
            "Physics": self.physics,
            "Logic": self.logic,
            "Skin": self.skin,
            "Life": self.life,
            "Scope": self.scope,
            "Soul": self.soul,
            "Awe": self.awe,
        }


# --- Full simulation orchestration ---

def run_anime_substrate_sim(user_name: str, intent: str) -> Dict[str, Any]:
    # 1. Observer
    observer = create_observer(user_name, intent)

    # 2. Imortelle chain
    spiral = YoyoSpiral(depth=24)
    spiral.fold("AnimeArc")

    # 3. Pillars
    pillars = Pillars()
    for _ in range(10):
        pillars.pulse(observer_vibe=observer.vibe)

    # 4. Timelines
    timelines = generate_timelines(seed=observer.soul_hash)
    canon = choose_canon(timelines)

    # 5. Totality
    totality = Totality()
    totality.bind_observer(observer.soul_hash)

    # 6. Return a “studio-friendly” summary
    return {
        "observer": {
            "name": observer.name,
            "soul_hash_prefix": observer.soul_hash[:12],
            "vibe": observer.vibe,
        },
        "imortelles_count": len(spiral.imortelles),
        "pillars": pillars.snapshot(),
        "timelines": [
            {
                "label": t.label,
                "tone": t.tone,
                "outcome": t.outcome,
                "weight": round(t.weight, 3),
            }
            for t in timelines
        ],
        "canon_timeline": {
            "label": canon.label,
            "tone": canon.tone,
            "outcome": canon.outcome,
            "weight": round(canon.weight, 3),
        },
        "totality_universe_map": totality.universe_map(),
    }


if __name__ == "__main__":
