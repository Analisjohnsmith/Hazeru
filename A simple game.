using UnityEngine;

public class IhatovEventEngine : MonoBehaviour {
    public IhatovEvent[] events;
    public IhatovEcologyEngine ecology;
    public IhatovWeatherState weather;
    public IhatovMemoryField memory;
    public KenjiAttentionSystem attention;

    void Update() {
        foreach (var e in events) {
            if (CheckTrigger(e)) {
                TriggerEvent(e);
            }
        }
    }

    bool CheckTrigger(IhatovEvent e) {
        float value = 0f;

        switch (e.source) {
            case IhatovEvent.TriggerSource.Ecology:
                value = ecology.ecologicalHealth;
                break;
            case IhatovEvent.TriggerSource.Weather:
                value = weather.intensity;
                break;
            case IhatovEvent.TriggerSource.MemoryBeauty:
                value = memory.memoryOfBeauty;
                break;
            case IhatovEvent.TriggerSource.MemorySuffering:
                value = memory.memoryOfSuffering;
                break;
            case IhatovEvent.TriggerSource.Attention:
                value = Mathf.Clamp01(attention.currentAttention / 10f);
                break;
        }

        return value >= e.triggerThreshold;
    }

    void TriggerEvent(IhatovEvent e) {
        foreach (var listener in FindObjectsOfType<IhatovEventListener>()) {
            if (listener.eventData == e) {
                listener.OnEventTriggered();
            }
        }

        if (e.oneShot) {
            e.triggerThreshold = float.MaxValue;
        }
    }
}
