// IhatovWeatherEngine.cs
using UnityEngine;

public class IhatovWeatherEngine : MonoBehaviour {
    public IhatovWeatherState weather;
    public KenjiWorldState worldState;
    public KenjiAttentionSystem attention;
    public TrueSoilSuffering trueSoil;
    public float transitionSpeed = 0.4f;

    void Update() {
        switch (worldState.chosenPath) {

            case KenjiPath.BeautifulDream:
                weather.currentWeather = IhatovWeatherType.GentleRain;
                weather.intensity = Mathf.MoveTowards(
                    weather.intensity,
                    Mathf.Clamp01(attention.currentAttention / 10f),
                    Time.deltaTime * transitionSpeed
                );
                break;

            case KenjiPath.TrueSoil:
                weather.currentWeather = IhatovWeatherType.HeavyRain;
                weather.intensity = Mathf.MoveTowards(
                    weather.intensity,
                    trueSoil.currentSuffering,
                    Time.deltaTime * transitionSpeed
                );
                break;

            case KenjiPath.Bridge:
                weather.currentWeather = IhatovWeatherType.Mist;
                weather.intensity = Mathf.MoveTowards(
                    weather.intensity,
                    0.5f + (attention.currentAttention * 0.05f),
                    Time.deltaTime * transitionSpeed
                );
                break;

            case KenjiPath.None:
            default:
                weather.currentWeather = IhatovWeatherType.Stillness;
                weather.intensity = Mathf.MoveTowards(
                    weather.intensity,
                    0f,
                    Time.deltaTime * transitionSpeed
                );
                break;
        }
    }
}
