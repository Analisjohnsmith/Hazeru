using UnityEngine;

public class IhatovPresenceManager : MonoBehaviour {
    public IhatovEcologyEngine ecology;
    public IhatovMemoryField memory;
    public IhatovWeatherState weather;
    public IhatovTimeState timeState;
    public Transform player;

    void Update() {
        foreach (var p in FindObjectsOfType<IhatovPresence>()) {
            float dist = Vector3.Distance(player.position, p.transform.position);

            if (dist < p.awarenessRadius) {
                p.OnPlayerNearby();
            }

            p.OnEcologyShift(ecology.ecologicalHealth);
            p.OnMemoryShift(memory.memoryOfBeauty + memory.memoryOfSuffering);
            p.OnWeatherShift(weather.intensity);
            p.OnTimeShift(timeState.timeOfDay);
        }
    }
}
