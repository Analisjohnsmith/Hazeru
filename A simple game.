[System.Serializable]
public class PlanetConfig {
    public string name;
    public Transform star;
    public float semiMajorAxis = 100f;
    public float eccentricity = 0.1f;
    public float orbitalPeriod = 600f;
    public float inclination = 5f;
    public float argumentOfPeriapsis = 0f;
    public float longitudeOfAscendingNode = 0f;
    public float initialMeanAnomaly = 0f;
    public Transform body;
}

public class PlanetSystem : MonoBehaviour {
    public List<PlanetConfig> planets = new List<PlanetConfig>();

    void Update() {
        float t = TimeLoopManager.Instance.currentTime;
        foreach (var p in planets) {
            UpdatePlanet(p, t);
        }
    }

    void UpdatePlanet(PlanetConfig p, float t) {
        float n = 2f * Mathf.PI / p.orbitalPeriod;
        float M = p.initialMeanAnomaly + n * t;
        float E = SolveKepler(M, p.eccentricity);
        float v = 2f * Mathf.Atan2(
            Mathf.Sqrt(1 + p.eccentricity) * Mathf.Sin(E / 2f),
            Mathf.Sqrt(1 - p.eccentricity) * Mathf.Cos(E / 2f)
        );
        float r = p.semiMajorAxis * (1 - p.eccentricity * Mathf.Cos(E));

        Vector3 posOrbital = new Vector3(
            r * Mathf.Cos(v),
            0f,
            r * Mathf.Sin(v)
        );

        Quaternion rot =
            Quaternion.Euler(0f, p.longitudeOfAscendingNode, 0f) *
            Quaternion.Euler(p.inclination, 0f, 0f) *
            Quaternion.Euler(0f, p.argumentOfPeriapsis, 0f);

        if (p.star != null && p.body != null) {
            p.body.position = p.star.position + rot * posOrbital;
        }
    }

    float SolveKepler(float M, float e, int iterations = 8) {
        float E = M;
        for (int i = 0; i < iterations; i++) {
            float f = E - e * Mathf.Sin(E) - M;
            float fp = 1f - e * Mathf.Cos(E);
            E -= f / fp;
        }
        return E;
    }
}
