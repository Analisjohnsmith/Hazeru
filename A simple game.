using UnityEngine;
using System.IO;

public class IhatovContinuityManager : MonoBehaviour {
    public IhatovTimeState timeState;
    public IhatovEcologyEngine ecology;
    public IhatovMemoryField memory;
    public KenjiWorldState worldState;
    public Transform player;

    string SavePath => Path.Combine(Application.persistentDataPath, "ihatov_save.json");

    public void Save() {
        IhatovContinuityData data = new IhatovContinuityData {
            timeOfDay = timeState.timeOfDay,
            ecologicalHealth = ecology.ecologicalHealth,
            memoryBeauty = memory.memoryOfBeauty,
            memorySuffering = memory.memoryOfSuffering,
            memoryAttention = memory.memoryOfAttention,
            memoryKenji = memory.memoryOfKenjiPresence,
            chosenPath = (int)worldState.chosenPath,
            playerX = player.position.x,
            playerY = player.position.y,
            playerZ = player.position.z
        };

        File.WriteAllText(SavePath, JsonUtility.ToJson(data, true));
    }

    public void Load() {
        if (!File.Exists(SavePath)) return;

        var json = File.ReadAllText(SavePath);
        var data = JsonUtility.FromJson<IhatovContinuityData>(json);

        timeState.timeOfDay = data.timeOfDay;
        ecology.ecologicalHealth = data.ecologicalHealth;
        memory.memoryOfBeauty = data.memoryBeauty;
        memory.memoryOfSuffering = data.memorySuffering;
        memory.memoryOfAttention = data.memoryAttention;
        memory.memoryOfKenjiPresence = data.memoryKenji;
        worldState.chosenPath = (KenjiPath)data.chosenPath;

        player.position = new Vector3(data.playerX, data.playerY, data.playerZ);
    }
}
