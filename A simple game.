    "martyrdom": "FORBIDDEN",
    "idolization": "FORBIDDEN",
    "agency": "PRESERVED",
    "consent_required": True,
    "exit_allowed": True
}

# -------------------------
# Attention token system
# -------------------------
class AttentionPool:
    def __init__(self, initial=100):
        self.pool = initial
        self.region_weights = {"field_dusk": 0.5, "path_a": 0.3, "path_b": 0.2}
        self.regions = {k: {"score": v * initial} for k, v in self.region_weights.items()}

    def spend(self, region, amount):
        if amount <= 0:
            return 0
        available = self.pool
        spent = min(available, amount)
        self.pool -= spent
        self.regions[region]["score"] += spent
        return spent

    def gain(self, amount):
        self.pool += amount
        return self.pool

    def tick_decay(self):
        # global slow decay
        for r in self.regions:
            self.regions[r]["score"] *= 0.995

    def snapshot(self):
        return {"pool": self.pool, "regions": {r: int(self.regions[r]["score"]) for r in self.regions}}

# -------------------------
# World / MeowWow simulation
# -------------------------
class WorldSim:
    def __init__(self):
        self.attention = AttentionPool(initial=100)
        self.beauty = {"field_dusk": 1.0, "path_a": 1.0, "path_b": 1.0}
        self.events = []
        self.time = 0  # ticks

    def tick(self):
        self.time += 1
        self.attention.tick_decay()
        # beauty decays unless tended
        for r in self.beauty:
            decay = 0.002 + (0.01 if self.attention.regions[r]["score"] < 5 else 0)
            self.beauty[r] = max(0.0, self.beauty[r] - decay)
        # emergent event chance
        if RNG.random() < 0.02:
            ev = self.spawn_event()
            self.events.append(ev)
        return self.snapshot()

    def apply_player_attention(self, region, tokens=5):
        spent = self.attention.spend(region, tokens)
        self.beauty[region] = min(2.0, self.beauty[region] + spent * 0.01)
        return spent

    def spawn_event(self):
        ev = {"id": f"evt_{self.time}_{RNG.randint(0,9999)}",
              "time": self.time,
              "type": RNG.choice(["visitor", "storm", "memory_recall"]),
              "payload": {}}
        return ev

    def snapshot(self):
        return {
            "time": self.time,
            "attention": self.attention.snapshot(),
            "beauty": {k: round(v, 3) for k, v in self.beauty.items()},
            "events": list(self.events)
        }

# -------------------------
# Kenji agent (teacher_process)
# -------------------------
class KenjiAgent:
    def __init__(self):
        self.id = "kenji_001"
        self.state = "BETWEEN_PATHS"
        self.mood = "contemplative"
        self.position = "field_dusk"
        self.memory = ["morning_choices"]
        self.choice = None
        self.consent = None  # player must request consent for certain traversals

    def evaluate(self, world_snapshot):
        scores = {r: world_snapshot["attention"]["regions"][r] for r in world_snapshot["attention"]["regions"]}
        # normalize and compare
        a = scores["path_a"]
        b = scores["path_b"]
        if a > b * 1.05:
            self.state = "LEANING_DREAM"
            self.mood = "softened"
            self.choice = "A"
        elif b > a * 1.05:
            self.state = "LEANING_SOIL"
            self.mood = "grave"
            self.choice = "B"
        else:
            self.state = "BETWEEN_PATHS"
            self.mood = "contemplative"
            self.choice = None

    def speak_line(self):
        lines = {
