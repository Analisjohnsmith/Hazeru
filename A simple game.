using UnityEngine;

public class IhatovBiomeGenerator : MonoBehaviour {
    public KenjiWorldState worldState;
    public IhatovEcologyEngine ecology;
    public IhatovMemoryField memory;
    public IhatovWeatherState weather;

    public GameObject dreamPrefab;
    public GameObject soilPrefab;
    public GameObject bridgePrefab;
    public GameObject neutralPrefab;

    public int biomeCount = 12;
    public float radius = 40f;

    void Start() {
        GenerateBiomes();
    }

    void GenerateBiomes() {
        for (int i = 0; i < biomeCount; i++) {
            float angle = (float)i / biomeCount * Mathf.PI * 2f;
            Vector3 pos = transform.position + new Vector3(
                Mathf.Cos(angle) * radius,
                0f,
                Mathf.Sin(angle) * radius
            );

            GameObject prefab = ChoosePrefab();
            GameObject biome = Instantiate(prefab, pos, Quaternion.identity, transform);

            ApplyBiomeModifiers(biome);
        }
    }

    GameObject ChoosePrefab() {
        switch (worldState.chosenPath) {
            case KenjiPath.BeautifulDream:
                return dreamPrefab;
            case KenjiPath.TrueSoil:
                return soilPrefab;
            case KenjiPath.Bridge:
                return bridgePrefab;
            case KenjiPath.None:
            default:
                return neutralPrefab;
        }
    }

    void ApplyBiomeModifiers(GameObject biome) {
        float eco = ecology.ecologicalHealth;
        float memBeauty = memory.memoryOfBeauty;
        float memSuffering = memory.memoryOfSuffering;
        float weatherIntensity = weather.intensity;

        // Scale biome based on ecology
        float scale = Mathf.Lerp(0.8f, 1.4f, eco);
        biome.transform.localScale = Vector3.one * scale;

        // Tint biome based on memory
        Renderer r = biome.GetComponentInChildren<Renderer>();
        if (r != null) {
            MaterialPropertyBlock block = new MaterialPropertyBlock();
            r.GetPropertyBlock(block);

            Color baseColor = Color.Lerp(
                Color.gray * (0.5f + memSuffering),
                Color.white * (0.5f + memBeauty),
                eco
            );

            block.SetColor("_BaseColor", baseColor);
            r.SetPropertyBlock(block);
        }

        // Weather influence: slight vertical offset
        float offset = weatherIntensity * 0.5f;
        biome.transform.position += Vector3.up * offset;
    }
}

