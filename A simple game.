using UnityEngine;

public class IhatovEcologyEngine : MonoBehaviour {
    public KenjiWorldState worldState;
    public KenjiAttentionSystem attention;
    public IhatovWeatherState weather;
    public TrueSoilSuffering trueSoil;

    [Range(0f, 1f)]
    public float ecologicalHealth = 1f;

    public float recoveryRate = 0.15f;
    public float decayRate = 0.25f;

    void Update() {
        float target = ecologicalHealth;

        // BEAUTIFUL DREAM → ecology recovers with attention
        if (worldState.chosenPath == KenjiPath.BeautifulDream) {
            float attentionFactor = Mathf.Clamp01(attention.currentAttention / 10f);
            target += attentionFactor * recoveryRate * Time.deltaTime;
        }

        // TRUE SOIL → ecology decays with suffering
        if (worldState.chosenPath == KenjiPath.TrueSoil) {
            target -= trueSoil.currentSuffering * decayRate * Time.deltaTime;
        }

        // BRIDGE → ecology oscillates between both
        if (worldState.chosenPath == KenjiPath.Bridge) {
            float oscillation = Mathf.Sin(Time.time * 0.4f) * 0.1f;
            target += oscillation * Time.deltaTime;
        }

        // NO PATH → ecology drifts toward neutral
        if (worldState.chosenPath == KenjiPath.None) {
            target = Mathf.MoveTowards(target, 0.5f, Time.deltaTime * 0.1f);
        }

        ecologicalHealth = Mathf.Clamp01(target);
    }
}
