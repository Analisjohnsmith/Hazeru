using UnityEngine;

public class PlanetOrbit : MonoBehaviour {
    public Transform star;
    public float semiMajorAxis = 100f;
    public float eccentricity = 0.1f;
    public float orbitalPeriod = 600f; // seconds per orbit
    public float inclination = 5f;
    public float argumentOfPeriapsis = 0f;
    public float longitudeOfAscendingNode = 0f;
    public float initialMeanAnomaly = 0f;

    void Update() {
        float t = TimeLoopManager.Instance.currentTime;
        float n = 2f * Mathf.PI / orbitalPeriod; // mean motion
        float M = initialMeanAnomaly + n * t;
        float E = SolveKepler(M, eccentricity);
        float v = 2f * Mathf.Atan2(
            Mathf.Sqrt(1 + eccentricity) * Mathf.Sin(E / 2f),
            Mathf.Sqrt(1 - eccentricity) * Mathf.Cos(E / 2f)
        );
        float r = semiMajorAxis * (1 - eccentricity * Mathf.Cos(E));

        Vector3 posOrbital = new Vector3(
            r * Mathf.Cos(v),
            0f,
            r * Mathf.Sin(v)
        );

        Quaternion rot =
            Quaternion.Euler(0f, longitudeOfAscendingNode, 0f) *
            Quaternion.Euler(inclination, 0f, 0f) *
            Quaternion.Euler(0f, argumentOfPeriapsis, 0f);

        transform.position = star.position + rot * posOrbital;
    }

    float SolveKepler(float M, float e, int iterations = 8) {
        float E = M;
        for (int i = 0; i < iterations; i++) {
            float f = E - e * Mathf.Sin(E) - M;
            float fp = 1f - e * Mathf.Cos(E);
            E -= f / fp;
        }
        return E;
    }
}
