    public ParticleSystem gentleRain;
    public ParticleSystem heavyRain;
    public ParticleSystem mist;
    public AudioSource windAudio;

    void Update() {
        gentleRain.Stop();
        heavyRain.Stop();
        mist.Stop();
        windAudio.volume = 0f;

        switch (weather.currentWeather) {
