// IhatovAudioEngine.cs
using UnityEngine;

public class IhatovAudioEngine : MonoBehaviour {
    public IhatovAudioState audioState;
    public IhatovEcologyEngine ecology;
    public IhatovWeatherState weather;
    public IhatovMemoryField memory;
    public IhatovTimeState timeState;
    public KenjiPresence kenjiPresence;

    public AudioSource ambientSource;
    public AudioSource weatherSource;
    public AudioSource memorySource;
    public AudioSource kenjiSource;

    void Update() {
        UpdateAmbient();
        UpdateWeather();
        UpdateMemory();
        UpdateKenji();
    }

    void UpdateAmbient() {
        float t = timeState.timeOfDay;
        float eco = ecology.ecologicalHealth;

        audioState.ambientVolume = Mathf.Lerp(0.3f, 1.2f, eco) * Mathf.Sin(t * Mathf.PI);
        ambientSource.volume = audioState.ambientVolume;
    }

    void UpdateWeather() {
        audioState.weatherVolume = weather.intensity;
        weatherSource.volume = audioState.weatherVolume;
    }

    void UpdateMemory() {
        float mem = memory.memoryOfBeauty + memory.memoryOfSuffering;
        audioState.memoryVolume = Mathf.Clamp01(mem);
        memorySource.volume = audioState.memoryVolume;
    }

    void UpdateKenji() {
        float alpha = kenjiPresence != null
            ? kenjiPresence.GetComponent<SkinnedMeshRenderer>().sharedMaterial.color.a
            : 0f;

        audioState.kenjiVolume = alpha;
        kenjiSource.volume = audioState.kenjiVolume;
    }
}

