// IhatovAtmosphereFeedback.cs
using UnityEngine;
using UnityEngine.Rendering;
using UnityEngine.Rendering.Universal;

public class IhatovAtmosphereFeedback : MonoBehaviour {
    public IhatovEcologyEngine ecology;
    public IhatovMemoryField memory;
    public IhatovWeatherState weather;

    public Volume volume;
    ColorAdjustments color;
    Bloom bloom;
    Vignette vignette;

    void Start() {
        volume.profile.TryGet(out color);
        volume.profile.TryGet(out bloom);
        volume.profile.TryGet(out vignette);
    }

    void Update() {
        float eco = ecology.ecologicalHealth;
        float mem = memory.memoryOfBeauty - memory.memoryOfSuffering;
        float wet = weather.intensity;

        // Color shifts with memory
        color.saturation.value = Mathf.Lerp(-20f, 20f, mem);

        // Bloom increases with beauty
        bloom.intensity.value = Mathf.Lerp(0.5f, 2f, memory.memoryOfBeauty);

        // Vignette increases with suffering
        vignette.intensity.value = Mathf.Lerp(0.1f, 0.4f, memory.memoryOfSuffering);

        // Weather darkens the world
        color.postExposure.value = Mathf.Lerp(0f, -1f, wet);
    }
}
