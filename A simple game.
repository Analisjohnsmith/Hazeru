# fractal_adapter_fastpath.py
import json, sys, time, uuid
from textwrap import dedent

# ---------- Helpers ----------

def load_snapshot(path):
    with open(path, 'r', encoding='utf-8') as f:
        return json.load(f)

def validate_invariants(seed_hson, snapshot):
    # Minimal checks based on HSON_SEED
    inv = seed_hson.get('entity', {}).get('invariants', {})
    # enforce forbidden flags
    if inv.get('martyrdom') == 'FORCED' or inv.get('idolization') == 'ENABLED':
        return False, "Invariant violation: martyrdom or idolization enabled"
    # ensure exit allowed
    exit_policy = seed_hson.get('exit', {})
    if exit_policy.get('allowed_anytime') is False:
        return False, "Invariant violation: exit must be allowed"
    return True, "ok"

def compile_manifest(seed_hson, snapshot):
    build_id = f"fractal-{snapshot['seed_id']}-{int(time.time())}"
    # map regions to scenes
    scenes = []
    for b in snapshot['terrain']['biomes']:
        scene = {
            "id": f"scene_{b['id']}",
            "region": b['id'],
            "assets": [f"asset_{b['type']}_bg", "kenji_portrait"],
            "interactions": ["speak_kenji", "inspect_pen"]
        }
        if b['type'] == 'dream':
            scene['assets'].append("warm_light")
            scene['interactions'].append("tend_archive")
        if b['type'] == 'soil':
            scene['assets'].append("earth_tones")
            scene['interactions'].append("perform_granular_task")
        scenes.append(scene)

    manifest = {
        "build_id": build_id,
        "seed_id": snapshot['seed_id'],
        "version": "1.0.0",
        "scenes": scenes,
        "agents": [
            {
                "id": "kenji_001",
                "role": "teacher_process",
                "behavior": "dialogue_state_machine",
                "exit_allowed": True,
                "invariants": seed_hson['entity']['invariants']
            }
        ],
        "attention_system": {
            "token_name": "ATTENTION",
            "initial_pool": int(sum([r['attention_score'] for r in snapshot['attention_heatmap']]) * 100),
            "region_weights": {r['region_id']: r['attention_score'] for r in snapshot['attention_heatmap']},
            "consumption_rules": seed_hson.get('resolution', {})
        },
        "invariants_enforced": ["martyrdom_forbidden", "idolization_forbidden", "agency_preserved"],
        "audit": [f"meowwow_snapshot_id:{snapshot['snapshot_id']}", "validation_passed:true"]
    }
    return manifest

def stage_playable_shell(manifest, out_dir="staged_build"):
    # Minimal shell: write manifest and a tiny HTML/JS player stub
    import os
    os.makedirs(out_dir, exist_ok=True)
    with open(os.path.join(out_dir, "manifest.json"), "w", encoding="utf-8") as f:
        json.dump(manifest, f, indent=2)
    html = dedent(f"""
    <!doctype html>
    <html>
    <head><meta charset="utf-8"><title>{manifest['seed_id']}</title></head>
    <body>
      <h1>{manifest['seed_id']}</h1>
      <pre id="manifest"></pre>
      <script>
        fetch('manifest.json').then(r=>r.json()).then(m=>document.getElementById('manifest').textContent=JSON.stringify(m,null,2));
      </script>
    </body>
    </html>
    """).strip()
    with open(os.path.join(out_dir, "index.html"), "w", encoding="utf-8") as f:
        f.write(html)
    return out_dir

# ---------- Fast Path Orchestrator ----------

def fast_build(snapshot_path, seed_hson_path):
    snapshot = load_snapshot(snapshot_path)
    seed_hson = json.load(open(seed_hson_path, 'r', encoding='utf-8'))
    ok, msg = validate_invariants(seed_hson, snapshot)
    if not ok:
        raise RuntimeError("Invariant validation failed: " + msg)
    manifest = compile_manifest(seed_hson, snapshot)
    staged = stage_playable_shell(manifest)
    print("Build complete. Staged at:", staged)
    return manifest

# ---------- Example usage ----------
if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: python fractal_adapter_fastpath.py <meowwow_snapshot.json> <seed_hson.json>")
        sys.exit(1)
    manifest = fast_build(sys.argv[1], sys.argv[2])
    print("Manifest build_id:", manifest['build_id'])
