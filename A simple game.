            case IhatovWeatherType.Mist:
                var m = mist.main;
                m.startLifetime = 1f + weather.intensity;
                mist.Play();
                break;

            case IhatovWeatherType.Wind:
                windAudio.volume = weather.intensity;
                break;

            case IhatovWeatherType.Stillness:
