def _dot(v1: List[float], v2: List[float]) -> float:
    n = min(len(v1), len(v2))
    return sum(v1[i] * v2[i] for i in range(n))

def _norm(v: List[float]) -> float:
    return math.sqrt(sum(x * x for x in v))

def psi_metric(state: MindState) -> float:
    x = state.world_model.get("world_model_vector", [0.0])
    x_hat = state.subject.get("self_model_vector", [0.0])
    num = _dot(x, x_hat)
    den = _norm(x) * _norm(x_hat)
    return num / den if den else 0.0

def C_metric(state: MindState) -> float:
    x = state.world_model.get("world_model_vector", [0.0])
    x_hat = state.subject.get("self_model_vector", [0.0])
    n = max(len(x), len(x_hat))
    x2 = (x + [0.0] * n)[:n]
    h2 = (x_hat + [0.0] * n)[:n]
    err = math.sqrt(sum((x2[i] - h2[i]) ** 2 for i in range(n)))
    return -math.log(err * err + 1e-9)

def gamma_metric(state: MindState, prev_state: MindState) -> float:
    x = state.world_model.get("world_model_vector", [0.0])
    x_prev = prev_state.world_model.get("world_model_vector", [0.0])
    if not x or not x_prev:
        return 0.0

    def _normalize(v: List[float]) -> List[float]:
        v_abs = [abs(a) + 1e-6 for a in v]
        s = sum(v_abs)
        return [a / s for a in v_abs] if s else [1.0 / len(v_abs)] * len(v_abs)

    p = _normalize(x)
    q = _normalize(x_prev)
    n = min(len(p), len(q))
    kl = 0.0
    for i in range(n):
        kl += p[i] * math.log(p[i] / q[i])
    return kl

