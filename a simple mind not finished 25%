class LyraPackageBuilder:
    @staticmethod
    def build(source_dir: str, output_path: str) -> None:
        manifest_path = os.path.join(source_dir, "package.json")
        if not os.path.exists(manifest_path):
            raise RuntimeError("Missing package.json")
        if not output_path.endswith(".lfpkg"):
            output_path += ".lfpkg"
        with zipfile.ZipFile(output_path, "w", zipfile.ZIP_DEFLATED) as z:
            for root, _, files in os.walk(source_dir):
                for f in files:
                    full = os.path.join(root, f)
                    rel = os.path.relpath(full, source_dir)
                    z.write(full, rel)
        print(f"Built: {output_path}")

    @staticmethod
    def init(path: str, name: str, version: str) -> None:
        os.makedirs(path, exist_ok=True)
        manifest = {"name": name, "version": version, "entrypoints": {"default": "main.py"}}
        with open(os.path.join(path, "package.json"), "w") as f:
            json.dump(manifest, f, indent=2)
        with open(os.path.join(path, "main.py"), "w") as f:
            f.write('print("Hello from", __name__)\n')
        print(f"Initialized package at {path}")

class LyraInstaller:
    @staticmethod
    def install(bundle_path: str) -> None:
        if not zipfile.is_zipfile(bundle_path):
            raise RuntimeError("Invalid .lfpkg")
        with zipfile.ZipFile(bundle_path, "r") as z:
            with z.open("package.json") as f:
                manifest = json.load(f)
            target = os.path.join(PKG_STORE, f"{manifest['name']}-{manifest['version']}")
            os.makedirs(target, exist_ok=True)
            z.extractall(target)
        state = load_state()
        state["packages"][manifest["name"]] = {"version": manifest["version"], "path": target, "installed": timestamp()}
        save_state(state)
        print(f"Installed {manifest['name']}@{manifest['version']}")

    @staticmethod
    def run(name: str) -> int:
        state = load_state()
        pkg = state["packages"].get(name)
        if not pkg:
            print(f"Package not found: {name}")
            return 1
        main_py = os.path.join(pkg["path"], "main.py")
        if os.path.exists(main_py):
            return subprocess.run([sys.executable, main_py]).returncode
        print(f"No entrypoint found for {name}")
        return 1

