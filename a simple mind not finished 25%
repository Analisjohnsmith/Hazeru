class PersistentMemory:
    def __init__(self):
        self.conn = sqlite3.connect(CONFIG["db_path"])
        self._init_tables()
    
    def _init_tables(self):
        self.conn.executescript("""
            CREATE TABLE IF NOT EXISTS beliefs (
                id TEXT PRIMARY KEY,
                statement TEXT,
                confidence REAL,
                evidence_count INTEGER,
                last_updated TIMESTAMP
            );
            CREATE TABLE IF NOT EXISTS experiments (
                id TEXT PRIMARY KEY,
                hypothesis TEXT,
                result_json TEXT,
                p_value REAL,
                effect_size REAL,
                confirmed INTEGER,
                timestamp TIMESTAMP
            );
            CREATE TABLE IF NOT EXISTS discoveries (
                id TEXT PRIMARY KEY,
                discovery TEXT,
                confidence REAL,
                source TEXT,
                timestamp TIMESTAMP
            );
            CREATE TABLE IF NOT EXISTS curiosity_gaps (
                id TEXT PRIMARY KEY,
                gap_description TEXT,
                priority REAL,
                resolved INTEGER,
                created TIMESTAMP
            );
            CREATE TABLE IF NOT EXISTS self_code (
                id TEXT PRIMARY KEY,
                module_name TEXT,
                code TEXT,
                version INTEGER,
                active INTEGER,
                created TIMESTAMP
            );
        """)
        self.conn.commit()
    
    def update_belief(self, statement: str, confidence: float):
        hid = hashlib.md5(statement.encode()).hexdigest()[:16]
        cur = self.conn.cursor()
        cur.execute("SELECT confidence, evidence_count FROM beliefs WHERE id = ?", (hid,))
        row = cur.fetchone()
        if row:
            old_conf, cnt = row
            new_conf = old_conf + (confidence - old_conf) / (cnt + 1)
            cur.execute("UPDATE beliefs SET confidence = ?, evidence_count = ?, last_updated = ? WHERE id = ?",
                        (new_conf, cnt+1, datetime.now().isoformat(), hid))
        else:
            cur.execute("INSERT INTO beliefs (id, statement, confidence, evidence_count, last_updated) VALUES (?,?,?,?,?)",
                        (hid, statement, confidence, 1, datetime.now().isoformat()))
        self.conn.commit()
    
    def get_belief(self, statement: str) -> float:
        hid = hashlib.md5(statement.encode()).hexdigest()[:16]
        cur = self.conn.cursor()
        cur.execute("SELECT confidence FROM beliefs WHERE id = ?", (hid,))
        row = cur.fetchone()
        return row[0] if row else 0.5
    
    def save_discovery(self, discovery: str, confidence: float, source: str):
        did = hashlib.md5(discovery.encode()).hexdigest()[:16]
        cur = self.conn.cursor()
        cur.execute("INSERT OR REPLACE INTO discoveries (id, discovery, confidence, source, timestamp) VALUES (?,?,?,?,?)",
                    (did, discovery, confidence, source, datetime.now().isoformat()))
        self.conn.commit()
    
    def get_all_beliefs(self, min_conf=0.0) -> List[Dict]:
        cur = self.conn.cursor()
        cur.execute("SELECT statement, confidence FROM beliefs WHERE confidence >= ? ORDER BY confidence DESC", (min_conf,))
        return [{"statement": r[0], "confidence": r[1]} for r in cur.fetchall()]
    
    def save_experiment(self, hyp: str, result: Dict):
        eid = hashlib.md5(f"{hyp}{time.time()}".encode()).hexdigest()[:16]
        cur = self.conn.cursor()
        cur.execute("INSERT INTO experiments (id, hypothesis, result_json, p_value, effect_size, confirmed, timestamp) VALUES (?,?,?,?,?,?,?)",
                    (eid, hyp, json.dumps(result), result.get("p", 0.5), result.get("d", 0), int(result.get("confirmed", False)), datetime.now().isoformat()))
        self.conn.commit()
    
    def close(self):
        self.conn.close()

