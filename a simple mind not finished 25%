class CognitiveLenses:
    @staticmethod
    def measure(text: str) -> Dict[str, float]:
        words = text.split()
        wc = len(words)
        uw = len(set(words))
        fd = 1.0 + (uw / max(wc, 1) * 0.5) + (min(1.0, text.count('(') / 10) * 0.5)
        fd = min(2.0, fd)
        clarity = 0.5
        if wc < 20: clarity += 0.1
        if uw / max(wc,1) > 0.6: clarity += 0.1
        for v in ["maybe","perhaps","sort of"]:
            if v in text.lower(): clarity -= 0.05
        clarity = max(0.0, min(1.0, clarity))
        tension = 0.0
        opposites = [("good","bad"), ("true","false"), ("always","never")]
        for a,b in opposites:
            if a in text.lower() and b in text.lower(): tension += 0.15
        for e in ["angry","frustrated","stuck"]:
            if e in text.lower(): tension += 0.1
        tension = min(1.0, tension)
        integration = 0.3
        if clarity > 0.6: integration += 0.2
        if tension < 0.4: integration += 0.2
        integration = min(1.0, integration)
        necessity = 0.3
        for e in ["is","are","was","were"]:
            if f" {e} " in f" {text.lower()} ": necessity += 0.05
        for n in ["should","ought","must"]:
            if n in text.lower(): necessity -= 0.1
        necessity = max(0.0, min(1.0, necessity))
        novelty = min(1.0, uw / max(10,wc) * 2)
        actionability = 0.2
        for a in ["will","can","test","measure"]:
            if a in text.lower(): actionability += 0.1
        if text.strip().endswith('?'): actionability += 0.2
        actionability = min(1.0, actionability)
        return {
            "fractal_depth": fd, "clarity": clarity, "tension": tension,
            "integration": integration, "necessity": necessity,
            "novelty": novelty, "actionability": actionability
        }

