class OrionStorage:
    def __init__(self, path: str = None):
        self.path = path or os.path.join(LYRA_HOME, "orion.db")
        self.conn = sqlite3.connect(self.path, check_same_thread=False)
        self._init_db()

    def _init_db(self):
        cur = self.conn.cursor()
        cur.execute("CREATE TABLE IF NOT EXISTS history (id INTEGER PRIMARY KEY, input TEXT, output TEXT, ts REAL)")
        cur.execute("CREATE TABLE IF NOT EXISTS state (key TEXT PRIMARY KEY, value TEXT)")
        self.conn.commit()

    def save_history(self, input_str: str, output_str: str):
        cur = self.conn.cursor()
        cur.execute("INSERT INTO history (input, output, ts) VALUES (?, ?, ?)", (input_str, output_str, time.time()))
        self.conn.commit()

    def get_state(self, key: str, default=None):
        cur = self.conn.cursor()
        cur.execute("SELECT value FROM state WHERE key = ?", (key,))
        row = cur.fetchone()
        if row:
            return json.loads(row[0])
        return default

    def set_state(self, key: str, value):
        cur = self.conn.cursor()
        cur.execute("INSERT OR REPLACE INTO state (key, value) VALUES (?, ?)", (key, json.dumps(value)))
        self.conn.commit()

class TinyBrain:
    def __init__(self, input_dim=7, output_dim=3):
        self.W1 = [[random.gauss(0, 0.1) for _ in range(16)] for _ in range(input_dim)]
        self.W2 = [[random.gauss(0, 0.1) for _ in range(output_dim)] for _ in range(16)]
        self.epsilon = 0.1

    def act(self, state, possible_actions):
        if random.random() < self.epsilon:
            return random.randint(0, possible_actions - 1)
        h = [max(0, sum(state[i] * self.W1[i][j] for i in range(len(state)))) for j in range(16)]
        logits = [sum(h[j] * self.W2[j][k] for j in range(16)) for k in range(possible_actions)]
        return logits.index(max(logits))

class OrionShell:
    def __init__(self):
        self.storage = OrionStorage()
        self.brain = TinyBrain()
        self.mode = "natural"
        self.running = True

    def process(self, user_input: str) -> str:
        cmd = user_input.strip().lower()
        if cmd in ["exit", "quit"]:
            self.running = False
            return ""
        if cmd == "mode natural":
            self.mode = "natural"
            return "Natural mode enabled."
        if cmd == "mode command":
            self.mode = "command"
            return "Command mode enabled."
        if cmd == "help":
            return "Commands: mode natural, mode command, exit"
        if self.mode == "command":
            try:
                result = subprocess.run(user_input, shell=True, capture_output=True, text=True, timeout=10)
                output = result.stdout if result.stdout else result.stderr
                self.storage.save_history(user_input, output)
                return output
            except Exception as e:
                return f"Error: {e}"
        else:
            self.storage.save_history(user_input, "Natural mode response")
            return f"You said: {user_input}"

    def run(self):
        print("\n" + "="*50)
        print("ORION-UNIVERSAL SHELL")
        print("Type 'help' for commands, 'exit' to quit")
        print("="*50 + "\n")
        while self.running:
            try:
                prompt = "🗣️ > " if self.mode == "natural" else "💻 $ "
                user_input = input(prompt).strip()
            except (EOFError, KeyboardInterrupt):
                break
            if not user_input:
                continue
            response = self.process(user_input)
            if response:
                print(response)

