class Node:
    def __init__(self, uid: str, value: Any = None, parent: Optional["Node"] = None,
                 tags: Optional[List[str]] = None, style: Optional[Dict] = None,
                 data: Optional[Dict] = None):
        self.uid = uid
        self.value = value
        self.parent = parent
        self.children: Dict[str, Node] = {}
        self.tags = tags or []
        self.style = style or {}
        self.data = data or {}

    def add_child(self, name: str, value: Any = None) -> "Node":
        child_uid = f"{self.uid}/{name}" if self.uid != "/" else f"/{name}"
        child = Node(uid=child_uid, value=value, parent=self)
        self.children[name] = child
        return child

    def get(self, path: str) -> Optional["Node"]:
        if path == "/":
            return self.root() if self.parent else self
        parts = [p for p in path.split("/") if p]
        node = self.root()
        for p in parts:
            node = node.children.get(p)
            if node is None:
                return None
        return node

    def root(self) -> "Node":
        if self.parent is None:
            return self
        return self.parent.root()

    def __repr__(self):
        return f"Node({self.uid})"

class Tree:
    def __init__(self):
        self.root = Node(uid="/", value="root")

    def get(self, path: str) -> Optional[Node]:
        if path == "/":
            return self.root
        return self.root.get(path)

    def create_path(self, path: str, value: Any = None) -> Node:
        if path == "/":
            return self.root
        parts = [p for p in path.split("/") if p]
        current = self.root
        for i, part in enumerate(parts):
            if part not in current.children:
                partial = "/" + "/".join(parts[:i+1])
                current.children[part] = Node(uid=partial, parent=current)
            current = current.children[part]
        if value is not None:
            current.value = value
        return current

