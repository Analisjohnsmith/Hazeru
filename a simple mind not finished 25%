class FractalNecessityEngine:
    @staticmethod
    def decompose(text: str, depth: int = 4) -> Dict:
        layers = []
        current = text
        for i in range(depth):
            words = current.split()
            if i == 0:
                layer = {"level": i+1, "name": "whole", "content": current[:100]}
            elif i == 1:
                layer = {"level": i+1, "name": "core component", "content": current.split()[0] if words else ""}
            else:
                layer = {"level": i+1, "name": "primitive", "content": current[:50] if current else ""}
            layers.append(layer)
            current = " ".join(words[:max(1, len(words)//2)]) if words else ""
        return {"layers": layers}
    
    @staticmethod
    def eliminate_impossibilities(text: str, metrics: Dict) -> List[str]:
        imp = []
        if "true" in text.lower() and "false" in text.lower() and "both" not in text.lower():
            imp.append("Contradiction: 'true' and 'false' without resolution")
        if "always" in text.lower() and "never" in text.lower():
            imp.append("Contradiction: 'always' and 'never' cannot both hold")
        if metrics.get("necessity",0) < 0.4 and ("absolutely" in text.lower() or "definitely" in text.lower()):
            imp.append("Claim of certainty without empirical support")
        return imp

