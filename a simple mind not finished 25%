            return 0
        mx, my = sum(x)/len(x), sum(y)/len(y)
        num = sum((x[i]-mx)*(y[i]-my) for i in range(len(x)))
        den = math.sqrt(sum((xi-mx)**2 for xi in x) * sum((yi-my)**2 for yi in y))
        return num/den if den else 0

