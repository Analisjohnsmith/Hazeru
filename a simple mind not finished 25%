def main():
    parser = argparse.ArgumentParser(prog="lyra", description="LYRAFLOW - Complete Generative Platform")
    sub = parser.add_subparsers(dest="command", required=True)

    # FractalNatureOS commands
    p = sub.add_parser("fractal", help="Run FractalNatureOS")
    p.add_argument("command", choices=["generate"])
    p.add_argument("domain", help="Domain name (e.g., genstudio)")
    p.add_argument("node_path", help="Node path")
    p.add_argument("--dim", type=int, default=8)
    p.add_argument("--export", choices=["json", "pretty"])
    p.add_argument("--out-dir", default="output")

    # GenPipe commands
    p = sub.add_parser("genpipe", help="Run GenPipe")
    p.add_argument("--domain", required=True, choices=["music", "physics", "finance"])
    p.add_argument("--steps", type=int, default=10)

    # Orion commands
    p = sub.add_parser("orion", help="Run OrionUniversal shell")

    # Studio commands
    p = sub.add_parser("studio", help="Unified interactive studio")

    # Package management
    p = sub.add_parser("init", help="Initialize new package")
    p.add_argument("path")
    p.add_argument("--name", required=True)
    p.add_argument("--version", required=True)

    p = sub.add_parser("bundle", help="Build .lfpkg from directory")
    p.add_argument("source")
    p.add_argument("-o", "--output", required=True)

    p = sub.add_parser("install", help="Install .lfpkg bundle")
    p.add_argument("bundle")

    p = sub.add_parser("run", help="Run installed package")
    p.add_argument("name")

    p = sub.add_parser("list", help="List installed packages")

    args = parser.parse_args()

    if args.command == "fractal" and args.command == "generate":
        cmd_fractal_generate(args)
    elif args.command == "genpipe":
        cmd_genpipe_run(args)
    elif args.command == "orion":
        cmd_orion(args)
    elif args.command == "studio":
        cmd_studio(args)
    elif args.command == "init":
        LyraPackageBuilder.init(args.path, args.name, args.version)
    elif args.command == "bundle":
        cmd_bundle(args)
    elif args.command == "install":
        cmd_install(args)
    elif args.command == "run":
        cmd_run(args)
    elif args.command == "list":
        state = load_state()
        for name, info in state["packages"].items():
            print(f"{name}@{info['version']} - {info['path']}")
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
