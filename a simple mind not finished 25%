@dataclass
class MindState:
    t: int = 0
    subject: Dict[str, Any] = field(default_factory=dict)          # S_t
    workspace: List[Dict[str, Any]] = field(default_factory=list)  # G_t
    memory: Dict[str, Any] = field(default_factory=dict)           # summaries
