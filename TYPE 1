import matplotlib.pyplot as plt

plt.figure(figsize=(8, 8))
ax = plt.gca()
ax.set_facecolor("black")
plt.axis("off")

# Helper to draw a node
def node(x, y, label=None):
    plt.scatter(x, y, s=40, c="white")
    if label:
        plt.text(x, y+0.03, label, color="white", ha="center", fontsize=8)

# Helper to draw a connection
def connect(x1, y1, x2, y2, arrow=False):
    if arrow:
        plt.arrow(x1, y1, x2-x1, y2-y1,
                  length_includes_head=True,
                  head_width=0.02, head_length=0.04,
                  color="white")
    else:
        plt.plot([x1, x2], [y1, y2], color="white", linewidth=0.8)

# Central core
core_x, core_y = 0.0, 0.0
node(core_x, core_y, "CORE")

# Region centers
regions = {
    "THRESHOLD": (-0.6, -0.6),
    "FIELD":     (0.6, -0.6),
    "MIRROR":    (-0.8, 0.2),
    "ASCENT":    (0.8, 0.4),
    "CROWN":     (0.0, 0.8),
}

# Draw region centers and labels
for name, (x, y) in regions.items():
    node(x, y, name)
    # connect region to core
    connect(core_x, core_y, x, y, arrow=True)

# Simple internal nodes per region
import math
for name, (cx, cy) in regions.items():
    for i in range(4):
        angle = 2 * math.pi * i / 4
        r = 0.15
        x = cx + r * math.cos(angle)
        y = cy + r * math.sin(angle)
        node(x, y)
        connect(cx, cy, x, y)

# Feedback loop between regions (example)
connect(regions["THRESHOLD"][0], regions["THRESHOLD"][1],
        regions["FIELD"][0], regions["FIELD"][1])
connect(regions["FIELD"][0], regions["FIELD"][1],
        regions["MIRROR"][0], regions["MIRROR"][1])
connect(regions["MIRROR"][0], regions["MIRROR"][1],
        regions["ASCENT"][0], regions["ASCENT"][1])
connect(regions["ASCENT"][0], regions["ASCENT"][1],
        regions["CROWN"][0], regions["CROWN"][1])

plt.xlim(-1.2, 1.2)
plt.ylim(-1.2, 1.2)
plt.tight_layout()
plt.show()
