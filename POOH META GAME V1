// ============================================================================
// LOADER — LOAD PUBLIC‑DOMAIN POOH TEXTS FROM ./data/*.txt
// ============================================================================

fn load_pooh_texts(dir: &str) -> io::Result<Vec<String>> {
    let mut texts = Vec::new();

    for entry in fs::read_dir(dir)? {
        let entry = entry?;
        let path = entry.path();

        if path.extension().and_then(|s| s.to_str()) == Some("txt") {
            let mut file = fs::File::open(&path)?;
            let mut content = String::new();
            file.read_to_string(&mut content)?;
            texts.push(content);
        }
    }

    Ok(texts)
}

// ============================================================================
// PARSER — META‑BOOK STRUCTURE (SENTENCES + MOTIFS)
// ============================================================================

pub struct MetaBook {
    pub sentences: Vec<String>,
    pub motifs: Vec<String>,
}

fn parse_meta_book(texts: &[String]) -> MetaBook {
    let mut sentences = Vec::new();
    let mut motifs = Vec::new();

    for text in texts {
        for line in text.lines() {
            let trimmed = line.trim();
            if trimmed.len() > 3 {
                sentences.push(trimmed.to_string());
            }

            // Simple motif detection
            for motif in ["honey", "wind", "forest", "tracks", "dream"].iter() {
                if trimmed.to_lowercase().contains(motif) {
                    motifs.push(motif.to_string());
                }
            }
        }
    }

    MetaBook { sentences, motifs }
}

// ============================================================================
// EMOTIONAL PHYSICS — EMOTION ENUM + STATE
// ============================================================================

#[derive(Clone, PartialEq)]
pub enum Emotion {
    Fear,
    Sadness,
    Hunger,
    Calm,
}

#[derive(Clone)]
pub struct EmotionalState {
    pub current: Emotion,
}

impl EmotionalState {
    pub fn new() -> Self {
        Self {
            current: Emotion::Calm,
        }
    }

    pub fn set(&mut self, emotion: Emotion) {
        self.current = emotion;
    }
}

// ============================================================================
// META‑LAYER STATE + REWRITE
// ============================================================================

pub struct MetaState {
    pub loops: u32,
    pub awareness: f32,
    pub flags: Vec<String>,
}

impl MetaState {
    pub fn new() -> Self {
        Self {
            loops: 0,
            awareness: 0.0,
            flags: Vec::new(),
        }
    }

    pub fn increment_loop(&mut self) {
        self.loops += 1;
        self.awareness += 0.1;
        if self.awareness > 1.5 {
            self.awareness = 1.5;
        }
    }

    pub fn trigger(&mut self, flag: &str) {
        let f = flag.to_string();
        if !self.flags.contains(&f) {
            self.flags.push(f);
        }
    }

    pub fn is_triggered(&self, flag: &str) -> bool {
        self.flags.contains(&flag.to_string())
    }
}

fn meta_rewrite(text: &str, meta: &MetaState) -> String {
    let mut rng = thread_rng();
    let mut s = text.to_string();

    // As awareness increases, the text becomes self‑aware
    if meta.awareness > 0.3 {
        let inserts = vec![
            "…but something feels slightly off.",
            "You sense the story watching you.",
            "A page rustles, though there is no wind.",
            "The forest pauses, as if waiting for your choice.",
        ];

        if let Some(insert) = inserts.choose(&mut rng) {
            s.push(' ');
            s.push_str(insert);
        }
    }

    // At high awareness, the story breaks the frame
    if meta.awareness > 0.6 {
        s.push_str(" You feel as though the book is trying to speak to you.");
    }

    s
}

// ============================================================================
// SCENE GENERATOR — BASED ON META‑BOOK + EMOTIONAL PHYSICS
// ============================================================================

pub struct GeneratedScene {
    pub text: String,
    pub choices: Vec<(String, String)>, // (choice_text, next_scene_id)
}

fn apply_emotional_physics(sentence: String, state: &EmotionalState) -> String {
    let mut s = sentence;

    match state.current {
        Emotion::Fear => {
            s.push_str(" A faint fog rolls in, as if Piglet is worried about something.");
        }
        Emotion::Sadness => {
            s.push_str(" The colors seem a little duller today, like Eeyore’s mood is affecting the forest.");
        }
        Emotion::Hunger => {
            s.push_str(" You notice a gentle smell of honey drifting through the air.");
        }
        Emotion::Calm => {
            s.push_str(" Everything feels peaceful and warm.");
        }
    }

    s
}

fn generate_scene(meta: &MetaBook, state: &EmotionalState) -> GeneratedScene {
    let mut rng = thread_rng();

    // Pick a random sentence from the Pooh meta‑book
    let base_sentence = meta
        .sentences
        .choose(&mut rng)
        .unwrap_or(&"The forest is quiet today.".to_string())
        .clone();

    // Modify the sentence based on emotional physics
    let modified_sentence = apply_emotional_physics(base_sentence, state);

    // Generate choices based on motifs
    let mut choices = Vec::new();

    if meta.motifs.contains(&"honey".to_string()) {
        choices.push(("Follow the scent of honey".to_string(), "honey_path".to_string()));
    }

    if meta.motifs.contains(&"wind".to_string()) {
        choices.push(("Listen to the wind".to_string(), "wind_scene".to_string()));
    }

    if meta.motifs.contains(&"forest".to_string()) {
        choices.push(("Explore deeper into the forest".to_string(), "deep_forest_scene".to_string()));
    }

    // Always include a meta‑choice
    choices.push((
        "Open the meta‑book".to_string(),
        "meta_layer".to_string(),
    ));

    GeneratedScene {
        text: modified_sentence,
        choices,
    }
}

// ============================================================================
// DREAM LAYER — DESCRIPTION DISTORTION + DREAM SCENE
// ============================================================================

fn distort_description(desc: &str, awareness: f32) -> String {
    let mut s = desc.to_string();

    if awareness > 0.4 {
        s.push_str(" The trees seem to whisper fragments of old choices.");
    }

    if awareness > 0.7 {
        s.push_str(" Paths twist into shapes you almost recognize.");
    }

    if awareness > 1.0 {
        s.push_str(" You feel as though the forest is dreaming of you.");
    }

    s
}

fn generate_dream_scene(meta: &MetaBook, state: &EmotionalState, awareness: f32) -> GeneratedScene {
    let mut rng = thread_rng();

    let base = meta
        .sentences
        .choose(&mut rng)
        .unwrap_or(&"The dream shifts around you.".to_string())
        .clone();

    let mut text = format!("(dream) {}", base);

    if awareness > 0.5 {
        text.push_str(" You hear echoes of choices you made before.");
    }

    let mut choices = vec![
        ("Wake up in the deep forest".to_string(), "deep_forest".to_string()),
        ("Let the dream continue".to_string(), "dream_layer".to_string()),
    ];

    // Always allow returning to cottage eventually
    choices.push((
        "Return to the cottage".to_string(),
        "cottage".to_string(),
    ));

    GeneratedScene { text, choices }
}

// ============================================================================
// WORLD STRUCTURE — REGIONS, CONNECTIONS, GATES
