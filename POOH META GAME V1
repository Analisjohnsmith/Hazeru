// ============================================================================
// CHARACTERS — CORE EMOTION + LOCATION + AWARENESS
// ============================================================================

#[derive(Clone)]
pub struct Character {
    pub name: String,
    pub core_emotion: Emotion,
    pub location: String,
    pub awareness: f32,
}

impl Character {
    pub fn new(name: &str, emotion: Emotion, start: &str) -> Self {
        Self {
            name: name.to_string(),
            core_emotion: emotion,
            location: start.to_string(),
            awareness: 0.0,
        }
    }

    pub fn influence_emotion(&self, emotion: &mut EmotionalState) {
        emotion.set(self.core_emotion.clone());
    }

    pub fn tick(&mut self, meta: &MetaState) {
        // Characters become more aware as the meta-layer grows
        self.awareness += meta.awareness * 0.05;
        if self.awareness > 1.5 {
            self.awareness = 1.5;
        }
    }
}

fn create_characters() -> Vec<Character> {
    vec![
        Character::new("Pooh", Emotion::Hunger, "pooh_house"),
        Character::new("Piglet", Emotion::Fear, "piglet_hollow"),
        Character::new("Eeyore", Emotion::Sadness, "deep_forest"),
        Character::new("Christopher Robin", Emotion::Calm, "cottage"),
    ]
}

// ============================================================================
