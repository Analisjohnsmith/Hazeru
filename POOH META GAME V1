pub struct Region {
    pub id: String,
    pub description: String,
    pub connections: Vec<Connection>,
}

pub struct Connection {
    pub to: String,
    pub gate: Gate,
}

pub enum Gate {
    None,
    EmotionRequired(Emotion),
    MetaFlagRequired(String),
}

impl Region {
    pub fn is_accessible(&self, gate: &Gate, emotion: &EmotionalState, meta: &MetaState) -> bool {
        match gate {
            Gate::None => true,
            Gate::EmotionRequired(e) => &emotion.current == e,
            Gate::MetaFlagRequired(flag) => meta.is_triggered(flag),
        }
    }
}

