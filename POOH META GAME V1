            links: vec!["crown".to_string()],
        },
    );

    regions.insert(
        "ascent".to_string(),
        Region {
            id: "ascent".to_string(),
            name: "Honey Ascent".to_string(),
            nodes: ascent_nodes,
        },
    );

    // Crown
    let mut crown_nodes = HashMap::new();
    crown_nodes.insert(
        "crown".to_string(),
        RegionNode {
            id: "crown".to_string(),
            text: "Let everything you’ve said sit together like friends at a picnic.".to_string(),
            links: vec!["opening".to_string()],
        },
    );

    regions.insert(
        "crown".to_string(),
        Region {
            id: "crown".to_string(),
            name: "Picnic Crown".to_string(),
            nodes: crown_nodes,
        },
    );

    NarrativeMap { regions }
}

// ===============================
// RITUALS
// ===============================

fn synthesis(state: &mut WorldState) {
    state.presence += 0.05;
    state.clarity += 0.05;
    state.integration += 0.05;
    state.yin = (state.yin + 0.5) / 2.0;
    state.yang = (state.yang + 0.5) / 2.0;
    state.clamp();
}

// ===============================
// POOH SIMULATOR
// ===============================

struct PoohSimulator {
    state: WorldState,
    codex: Codex,
    map: NarrativeMap,
    current_region: String,
    current_node: String,
    memory: Vec<HashMap<String, String>>,
}

impl PoohSimulator {
    fn new() -> Self {
        Self {
            state: WorldState::new(),
            codex: build_codex(),
            map: build_narrative_map(),
            current_region: "threshold".to_string(),
            current_node: "opening".to_string(),
            memory: Vec::new(),
        }
    }

    fn narrative_node(&self) -> &RegionNode {
        let region = self.map.regions.get(&self.current_region).unwrap();
        region.nodes.get(&self.current_node).unwrap()
    }

    fn activate_codex(&self, prompt: &str) -> Vec<&CodexNode> {
        let words: Vec<String> = prompt
            .to_lowercase()
            .split_whitespace()
            .map(|s| s.to_string())
            .collect();

        let mut scored: Vec<(i32, &CodexNode)> = Vec::new();

        for node in self.codex.nodes.values() {
            let mut score = 0;
            for w in &words {
                if node.text.to_lowercase().contains(w) {
                    score += 1;
                }
            }
            if score > 0 {
                scored.push((score, node));
            }
        }

        scored.sort_by(|a, b| b.0.cmp(&a.0));
        scored.into_iter().map(|(_, n)| n).collect()
    }

    fn reason(&self, prompt: &str, nodes: Vec<&CodexNode>) -> String {
        if nodes.is_empty() {
            return "Pooh sits beside you quietly, offering gentle company.".to_string();
        }

        let mut phrases: Vec<String> = Vec::new();
        for n in nodes {
            for part in n.text.split('.') {
                let p = part.trim();
                if !p.is_empty() {
                    phrases.push(p.to_string());
                }
            }
        }

        let mut mem_lines: Vec<String> = Vec::new();
        for m in self.memory.iter().rev().take(5) {
            for v in m.values() {
                mem_lines.push(v.clone());
            }
        }

        let mut combined = phrases;
        combined.extend(mem_lines);

        let words: Vec<String> = prompt
            .to_lowercase()
            .split_whitespace()
            .map(|s| s.to_string())
            .collect();

        let mut relevant: Vec<String> = combined
            .into_iter()
            .filter(|line| {
                words
                    .iter()
                    .any(|w| line.to_lowercase().contains(&w.to_lowercase()))
            })
            .collect();

        if relevant.is_empty() {
            relevant = vec![
                "Pooh thinks slow thoughts are still good thoughts.".to_string(),
                "Pooh believes you don’t have to hurry.".to_string(),
                "Pooh feels you’re not alone here.".to_string(),
            ];
        }

        relevant.into_iter().take(3).collect::<Vec<_>>().join(" ")
    }

    fn detect_tone(&self, prompt: &str) -> &'static str {
        let p = prompt.to_lowercase();
        if ["sad", "hurt", "lost", "alone", "grief"]
            .iter()
            .any(|w| p.contains(w))
        {
            "comfort"
        } else if ["why", "meaning", "explain", "understand"]
            .iter()
            .any(|w| p.contains(w))
        {
            "clarity"
        } else if ["think", "reflect", "wonder"]
            .iter()
            .any(|w| p.contains(w))
        {
            "reflective"
        } else if ["hi", "hello", "hey"].iter().any(|w| p.contains(w)) {
            "warm"
        } else {
            "neutral"
        }
    }

    fn shape_voice(&self, prompt: &str, raw: String) -> (String, &'static str) {
        let tone = self.detect_tone(prompt);
        let s = &self.state;

        let voiced = match tone {
            "comfort" => format!("Pooh says softly: \"{}\"", raw),
            "clarity" => format!("Pooh thinks very hard and says: \"{}\"", raw),
            "reflective" => format!("Pooh tilts his head and says: \"{}\"", raw),
            "warm" => format!("Pooh smiles: \"{}\"", raw),
            _ => {
                if s.presence > 0.8 {
                    format!("Pooh feels very close to you and says: \"{}\"", raw)
                } else {
                    format!("Pooh says: \"{}\"", raw)
                }
            }
        };

        (voiced, tone)
    }

    fn check_transitions(&mut self) {
        let s = &self.state;
        let current = self.current_region.clone();

        let target = if current == "threshold" && s.presence > 0.30 {
            Some("field".to_string())
        } else if current == "field" && s.clarity > 0.35 {
            Some("mirror".to_string())
        } else if current == "mirror" && s.integration > 0.40 {
            Some("ascent".to_string())
        } else if current == "ascent"
            && s.presence > 0.55
            && s.clarity > 0.55
            && s.integration > 0.55
        {
            Some("crown".to_string())
        } else {
            None
        };

        if let Some(t) = target {
            self.current_region = t.clone();
            let region = self.map.regions.get(&t).unwrap();
            let first_key = region.nodes.keys().next().unwrap().clone();
            self.current_node = first_key;
        }
    }

    fn respond(&mut self, text: &str) -> (String, &'static str) {
        let mut mem_entry = HashMap::new();
        mem_entry.insert("user".to_string(), text.to_string());
        self.memory.push(mem_entry);

        if !text.trim().is_empty() {
            self.state.presence += 0.02;
        }
        if text.contains('?') {
            self.state.clarity += 0.02;
        } else {
            self.state.integration += 0.02;
        }
        self.state.clamp();

        let activated = self.activate_codex(text);
        let raw = self.reason(text, activated);
        let (pooh_voice, tone) = self.shape_voice(text, raw);

        let node = self.narrative_node();
        if !node.links.is_empty() {
            self.current_node = node.links[0].clone();
        }

        self.check_transitions();

        if self.current_region == "crown" {
            synthesis(&mut self.state);
        }

        let mut mem_reply = HashMap::new();
        mem_reply.insert("pooh".to_string(), pooh_voice.clone());
        self.memory.push(mem_reply);

        let out = format!("{}\n\n{}", pooh_voice, self.narrative_node().text);
        (out, tone)
    }
}

// ===============================
// PUBLIC ENTRY POINT FOR META-GAME
// ===============================

pub fn run_reflection(meta: &mut MetaState, emotion: &mut EmotionalState) {
    let mut sim = PoohSimulator::new();

    println!("\n✧ META‑BOOK: WINNIE THE POOH REFLECTION ✧\n");
    println!("{}", sim.narrative_node().text);

    loop {
        print!("\nYOU (meta‑book): ");
        io::stdout().flush().unwrap();

        let mut input = String::new();
        if io::stdin().read_line(&mut input).is_err() {
            println!("\nThe Wood grows quiet.");
            break;
        }

        let input = input.trim();
        if input.is_empty() {
            println!("\nThe Wood rustles softly.");
            continue;
        }

        if input.eq_ignore_ascii_case("exit")
            || input.eq_ignore_ascii_case("leave")
            || input.eq_ignore_ascii_case("close")
        {
            println!("\nThe Meta‑Book closes gently.");
            break;
        }

        let (reply, tone) = sim.respond(input);
        println!("\nPOOH (meta‑book):\n{}", reply);

        // hook into meta-state + emotional physics
        meta.awareness += 0.05;
        match tone {
            "comfort" => emotion.set(Emotion::Sadness),
            "clarity" => emotion.set(Emotion::Calm),
            "reflective" => emotion.set(Emotion::Calm),
            "warm" => emotion.set(Emotion::Calm),
            _ => {}
        }
    }

    meta.trigger("meta_book_reflected");
}
