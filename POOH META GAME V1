pub struct Interaction {
    pub text: String,
    pub choices: Vec<(String, InteractionEffect)>,
}

pub enum InteractionEffect {
    Emotion(Emotion),
    MetaFlag(String),
    AwarenessBoost(f32),
    None,
}

fn interact_with(name: &str) -> Interaction {
    match name {
        "Pooh" => Interaction {
            text: "Pooh looks at you warmly. \"I was thinking about honey today.\"".to_string(),
            choices: vec![
                ("Ask Pooh about honey".to_string(), InteractionEffect::Emotion(Emotion::Hunger)),
                ("Ask Pooh about the forest".to_string(), InteractionEffect::AwarenessBoost(0.1)),
                ("Say goodbye".to_string(), InteractionEffect::None),
            ],
        },

        "Piglet" => Interaction {
            text: "Piglet trembles slightly. \"Oh d‑d‑dear… is everything alright?\"".to_string(),
            choices: vec![
                ("Comfort Piglet".to_string(), InteractionEffect::Emotion(Emotion::Calm)),
                ("Ask what he's afraid of".to_string(), InteractionEffect::MetaFlag("piglet_fear_revealed".to_string())),
                ("Leave quietly".to_string(), InteractionEffect::None),
            ],
        },

        "Eeyore" => Interaction {
            text: "Eeyore sighs. \"Not much of a day, is it?\"".to_string(),
            choices: vec![
                ("Encourage Eeyore".to_string(), InteractionEffect::Emotion(Emotion::Calm)),
                ("Agree with him".to_string(), InteractionEffect::Emotion(Emotion::Sadness)),
                ("Ask why the forest feels strange".to_string(), InteractionEffect::AwarenessBoost(0.2)),
            ],
        },

        "Christopher Robin" => Interaction {
            text: "Christopher Robin smiles gently. \"The forest is changing. Have you noticed?\"".to_string(),
            choices: vec![
                ("Ask what he means".to_string(), InteractionEffect::AwarenessBoost(0.3)),
                ("Tell him you feel watched".to_string(), InteractionEffect::MetaFlag("player_awareness_ack".to_string())),
                ("Stay silent".to_string(), InteractionEffect::Emotion(Emotion::Calm)),
            ],
        },

        _ => Interaction {
            text: "There is no one here.".to_string(),
            choices: vec![("Continue".to_string(), InteractionEffect::None)],
        },
    }
}

// ============================================================================
// MAIN LOOP — WORLD NAVIGATION + SCENE GENERATION + META‑LAYER
// ============================================================================

fn main() {
    println!("🌳 Welcome to the Hundred Acre Meta‑Wood!");

    // Load Pooh texts and build meta‑book
    let raw_texts = load_pooh_texts("data").expect("Failed to load Pooh texts from ./data");
    let meta_book = parse_meta_book(&raw_texts);

    // Core simulation state
    let mut emotion = EmotionalState::new();
    let mut meta_state = MetaState::new();
    let mut world = build_world();
    let mut characters = create_characters();

    let mut current_region = "cottage".to_string();

    loop {
        // Update characters based on meta‑state
        for c in characters.iter_mut() {
            c.tick(&meta_state);
        }

        // Find current region
        let region = world
            .iter()
            .find(|r| r.id == current_region)
            .expect("Region not found");

        // Distort description if awareness is high (especially in dream layer)
        let base_desc = &region.description;
        let desc = if region.id == "dream_layer" {
            distort_description(base_desc, meta_state.awareness)
        } else {
            base_desc.clone()
        };

        println!("\n📍 You are in: {}\n", desc);

        // Show accessible connections
        let mut available = Vec::new();
        for (i, conn) in region.connections.iter().enumerate() {
            if region.is_accessible(&conn.gate, &emotion, &meta_state) {
                println!("{}. Go to {}", i + 1, conn.to);
                available.push(conn.to.clone());
            }
        }

        if available.is_empty() {
            println!("There seems to be nowhere to go from here. The forest waits.");
        }

        // Characters influence emotion if nearby and allow interaction
        for c in characters.iter() {
            if c.location == current_region {
                println!("\nYou see {} here.", c.name);

                let interaction = interact_with(&c.name);

                println!("\n{}\n", interaction.text);

                for (i, (choice_text, _)) in interaction.choices.iter().enumerate() {
                    println!("{}. {}", i + 1, choice_text);
                }

                let mut input = String::new();
                io::stdin().read_line(&mut input).unwrap();
                let index = input.trim().parse::<usize>().unwrap_or(1) - 1;

                if let Some((_, effect)) = interaction.choices.get(index) {
                    match effect {
                        InteractionEffect::Emotion(e) => emotion.set(e.clone()),
                        InteractionEffect::MetaFlag(flag) => {
                            meta_state.trigger(flag);
                            if flag == "player_awareness_ack" && meta_state.awareness < 0.8 {
                                meta_state.awareness = 0.8;
                            }
                        }
                        InteractionEffect::AwarenessBoost(a) => {
                            meta_state.awareness += *a;
                        }
                        InteractionEffect::None => {}
                    }
                }
            }
        }

        // Player chooses region
        if !available.is_empty() {
            println!("\nWhere will you go next?");
            let mut input = String::new();
            io::stdin().read_line(&mut input).unwrap();
            let index = input.trim().parse::<usize>().unwrap_or(1) - 1;

            if let Some(next) = available.get(index) {
                current_region = next.clone();
            } else {
                println!("You hesitate, and the forest gently nudges you to stay where you are.");
            }
        }

        // Generate scene inside region
        let mut scene = if current_region == "dream_layer" {
            generate_dream_scene(&meta_book, &emotion, meta_state.awareness)
        } else {
            generate_scene(&meta_book, &emotion)
        };

        // Apply meta‑layer rewriting
        scene.text = meta_rewrite(&scene.text, &meta_state);

        println!("\n{}\n", scene.text);

        for (i, (choice_text, _)) in scene.choices.iter().enumerate() {
            println!("{}. {}", i + 1, choice_text);
        }

        let mut input = String::new();
        io::stdin().read_line(&mut input).unwrap();
        let index = input.trim().parse::<usize>().unwrap_or(1) - 1;

        let next_scene = if let Some((_, ns)) = scene.choices.get(index) {
            ns.clone()
        } else {
            scene
                .choices
                .get(0)
                .map(|(_, ns)| ns.clone())
                .unwrap_or_else(|| "cottage".to_string())
        };

        // Emotional + meta triggers based on scene choice
        match next_scene.as_str() {
            "honey_path" => emotion.set(Emotion::Hunger),
            "wind_scene" => emotion.set(Emotion::Fear),
            "deep_forest_scene" => emotion.set(Emotion::Sadness),

            "meta_layer" => {
                reflection::run_reflection(&mut meta_state, &mut emotion);
                meta_state.trigger("opened_meta_book");
                continue;
            }

            "dream_layer" => {
                meta_state.trigger("awareness_high");
            }
            _ => {}
        }

        // Increase meta‑awareness each loop
        meta_state.increment_loop();
    }
}

