@dataclass(frozen=True)
class SymbolicOS:
    name: str
    version: str
    kernel_mode: str
    art_is_ui: bool
    processes: List[str]
    locked: bool = True

@dataclass(frozen=True)
class GameApp:
    name: str
    mode: str
    bound_scene_ids: List[str]
    art_is_game: bool
    art_is_app: bool
    locked: bool = True

@dataclass
class EngineRuntime:
    os: SymbolicOS
    app: GameApp
    scenes: Dict[str, Scene]
    active_scene_id: str
    engine_flags: Dict[str, bool]
    frame_rate: int
    color_space: str
    locked: bool = True

    @property
    def active_scene(self) -> Scene:
        return self.scenes[self.active_scene_id]

    def switch_scene(self, scene_id: str) -> None:
        if scene_id not in self.scenes:
            raise ValueError(f"Scene '{scene_id}' not registered.")
        if self.locked:
            # Even locked, we allow switching between pre-locked scenes
            object.__setattr__(self, "active_scene_id", scene_id)
        else:
            self.active_scene_id = scene_id

    def export_image_prompt(self) -> Dict[str, str]:
        """Export a fully fused prompt for image generation."""
        scene = self.active_scene
        env = scene.environment

        her_c = her
        him_c = him

        prompt = (
            "High-detail 8K anime/painterly scene where the art itself is the operating system, "
            "the engine, the app, and the fully functional game world. "
            f"Scene mode: {scene.mode.value} in a {env.biome.value.replace('_', ' ')} at {env.time_of_day.value}. "
            "No overlays, no HUD, no visible UI elements — the world itself is the interface. "
            f"{her_c.name}: green-haired woman with a yellow flower in her hair, soft {her_c.eye.base_color} eyes, "
            "natural, expressive face, wearing a light green off-shoulder dress, sitting or walking close to him, "
            "with a warm, serene expression. "
            f"{him_c.name}: blue-haired man with warm gold eyes, natural, expressive face, wearing a blue traditional robe "
            "with subtle swirl patterns, sitting or walking close to her, with a gentle, present expression. "
            "A fox is on the left and a duck on the right, acting as quiet companions. "
            "The meadow is dotted with small blue flowers, and the sunset light is warm, painterly, and cinematic, "
            "with Ghibli-level detail and symbolic harmony. "
        )

        if scene.mode == SceneMode.PICNIC:
            prompt += (
                "They sit together on a blanket with traditional Japanese picnic food: onigiri, small sweets, and a simple drink set. "
            )
        elif scene.mode == SceneMode.WALK:
            prompt += (
                "They walk along a forest path lined with blue flowers, framed by tall trees and dappled sunset light. "
            )

        return {
            "prompt": prompt,
            "resolution": f"{scene.resolution['width']}x{scene.resolution['height']}",
            "color_space": self.color_space
        }

