FPS = 30
SCREEN_SCALE = 0.5  # scale 8K backgrounds for display

# -----------------------------
# LOAD AIR FILE
# -----------------------------
def load_air_file(path):
    air_bytes = Path(path).read_bytes()
    air_str = air_bytes.decode("utf-8", errors="ignore")
    try:
        start = air_str.index("---SCENE_DATA_START---") + len("---SCENE_DATA_START---")
        end = air_str.index("---SCENE_DATA_END---")
        scene_json = air_str[start:end].strip()
        scenes = json.loads(scene_json)
        print("✅ Scene data loaded from AIR file.")
        return scenes
    except Exception as e:
        print("❌ Failed to load scene:", e)
        return {}

# -----------------------------
# LOAD ASSETS
# -----------------------------
def load_assets():
    assets = {
        "background_picnic": "assets/forest_meadow_picnic.png",
        "background_walk": "assets/forest_meadow_walk.png",
        "her": ["assets/her_blink1.png","assets/her_blink2.png"],
        "him": ["assets/him_blink1.png","assets/him_blink2.png"],
        "fox": ["assets/fox1.png","assets/fox2.png"],
        "duck": ["assets/duck1.png","assets/duck2.png"],
        "kitten": "assets/kitten.png",
        "flower": "assets/flower.png",
        "blanket": "assets/blanket.png"
    }
    loaded = {}
    for key, value in assets.items():
        if isinstance(value, list):
            loaded[key] = [pygame.image.load(v).convert_alpha() for v in value]
        else:
            loaded[key] = pygame.image.load(value).convert_alpha()
    return loaded

# -----------------------------
# STATE MANAGEMENT
# -----------------------------
STATE = {
    "kitten_summoned": False,
    "fox_active": False,
    "duck_active": False,
    "sunset_active": False,
    "current_scene": "picnic"
}

# -----------------------------
# SCENE MAP
# -----------------------------
SCENE_MAP = {
    "picnic": {"walk_path": "walk_scene"},
    "walk_scene": {"back_to_picnic": "picnic"}
}

# -----------------------------
# TRIGGERS / INTERACTIONS
# -----------------------------
def handle_trigger(trigger, companions, screen, assets):
    if trigger == "SUMMON : KITTEN" and not STATE["kitten_summoned"]:
        kitten_sprite = pygame.transform.scale(assets['kitten'], (100,100))
        screen.blit(kitten_sprite, (random.randint(100,700), random.randint(100,400)))
        STATE["kitten_summoned"] = True
        pygame.display.flip()
        pygame.time.delay(400)
    elif trigger == "fox_walk":
        STATE["fox_active"] = True
        companions['fox']['dx'] = 2
    elif trigger == "duck_waddle":
        STATE["duck_active"] = True
        companions['duck']['dx'] = 1.5
    elif trigger == "sunset_shift":
        STATE["sunset_active"] = True
        companions['sunset_tint'] = 50

# -----------------------------
# CLICK DETECTION
# -----------------------------
def check_click(pos, characters, environment_objects):
    x, y = pos
    for name, char in characters.items():
        rect = pygame.Rect(int(char['x']*SCREEN_SCALE), int(char['y']*SCREEN_SCALE),
                           int(char['sprites'][0].get_width()*0.5),
                           int(char['sprites'][0].get_height()*0.5))
        if rect.collidepoint(x,y):
            print(f">>> Clicked on {name}")
            handle_trigger("SUMMON : KITTEN", environment_objects, screen, assets)
    for obj_name, obj in environment_objects.items():
        rect = pygame.Rect(int(obj['x']*SCREEN_SCALE), int(obj['y']*SCREEN_SCALE),
                           int(obj['sprite'].get_width()*0.5),
                           int(obj['sprite'].get_height()*0.5))
        if rect.collidepoint(x,y):
            print(f">>> Clicked on {obj_name}")
            if obj_name == "blanket":
                handle_trigger("KITTEN:playtime", environment_objects, screen, assets)
            elif obj_name == "flower":
                handle_trigger("sunset_shift", environment_objects, screen, assets)

# -----------------------------
# RUN SCENE LOOP
# -----------------------------
def run_scene(scene_name, assets):
    pygame.init()
    bg_img = assets["background_picnic"] if scene_name=="picnic" else assets["background_walk"]
    width, height = bg_img.get_width(), bg_img.get_height()
    global screen
    screen = pygame.display.set_mode((int(width*SCREEN_SCALE), int(height*SCREEN_SCALE)))
    pygame.display.set_caption(WINDOW_TITLE)

    # Characters
    characters = {
        'her': {'sprites': assets['her'], 'x': width//2-150, 'y': height//2, 'blink_timer':0, 'frame':0},
        'him': {'sprites': assets['him'], 'x': width//2+150, 'y': height//2, 'blink_timer':0, 'frame':0}
    }

    # Companions
    companions = {
        'fox': {'sprites': assets['fox'], 'x':100, 'y':height//2, 'dx':0, 'frame':0},
        'duck': {'sprites': assets['duck'], 'x':300, 'y':height//2+100, 'dx':0, 'frame':0},
        'sunset_tint':0
    }

    # Environment objects
    environment_objects = {
        'blanket': {'sprite': assets['blanket'], 'x':width//2-50, 'y':height//2+100},
        'flower': {'sprite': assets['flower'], 'x':width//2+200, 'y':height//2-50}
    }

    clock = pygame.time.Clock()
    running = True
    step = 0

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.MOUSEBUTTONDOWN:
                check_click(event.pos, characters, {**companions, **environment_objects})

        # Animate character blink
        for char in characters.values():
            char['blink_timer'] += 1
            if char['blink_timer'] > random.randint(60,180):
                char['frame'] = 1
                if char['blink_timer'] > random.randint(65,200):
                    char['frame'] = 0
                    char['blink_timer'] = 0

        # Animate companions
        for comp in ['fox','duck']:
            if STATE[f"{comp}_active"]:
                companions[comp]['x'] += companions[comp]['dx']
                companions[comp]['frame'] = (companions[comp]['frame'] +1) % len(companions[comp]['sprites'])
                if companions[comp]['x'] > width:
                    companions[comp]['x'] = -companions[comp]['sprites'][0].get_width()

        # Draw background
        screen.blit(pygame.transform.scale(bg_img, (int(width*SCREEN_SCALE), int(height*SCREEN_SCALE))), (0,0))

        # Apply sunset tint if active
        if STATE["sunset_active"]:
            tint = pygame.Surface(screen.get_size(), pygame.SRCALPHA)
            tint.fill((255,100,50,companions['sunset_tint']))
            screen.blit(tint,(0,0))

        # Draw environment objects
        for obj in environment_objects.values():
            sprite_scaled = pygame.transform.scale(obj['sprite'],
                                                   (int(obj['sprite'].get_width()*0.5),
                                                    int(obj['sprite'].get_height()*0.5)))
            screen.blit(sprite_scaled, (int(obj['x']*SCREEN_SCALE), int(obj['y']*SCREEN_SCALE)))

        # Draw characters
        for char in characters.values():
            sprite_scaled = pygame.transform.scale(char['sprites'][char['frame']],
                                                   (int(char['sprites'][0].get_width()*0.5),
                                                    int(char['sprites'][0].get_height()*0.5)))
            screen.blit(sprite_scaled, (int(char['x']*SCREEN_SCALE), int(char['y']*SCREEN_SCALE)))

        # Draw companions
        for comp in ['fox','duck']:
            sprite_scaled = pygame.transform.scale(companions[comp]['sprites'][companions[comp]['frame']],
                                                   (int(companions[comp]['sprites'][0].get_width()*0.5),
                                                    int(companions[comp]['sprites'][0].get_height()*0.5)))
            screen.blit(sprite_scaled, (int(companions[comp]['x']*SCREEN_SCALE), int(companions[comp]['y']*SCREEN_SCALE)))

        pygame.display.flip()
        clock.tick(FPS)
        step += 1

        # Automatic demo triggers
        if step == 60:
            handle_trigger("fox_walk", companions, screen, assets)
        if step == 120:
            handle_trigger("duck_waddle", companions, screen, assets)
        if step == 180:
            handle_trigger("sunset_shift", companions, screen, assets)

        # Scene switching demo (clicking path object)
        if scene_name=="picnic" and step==300:
            print(">>> Switching to walk scene...")
            STATE["current_scene"]="walk_scene"
            run_scene("walk_scene", assets)
            return
        elif scene_name=="walk_scene" and step==300:
            print(">>> Switching back to picnic...")
            STATE["current_scene"]="picnic"
            run_scene("picnic", assets)
            return

    pygame.quit()

# -----------------------------
# MAIN
# -----------------------------
if __name__=="__main__":
    scenes = load_air_file(AIR_FILE)
    assets = load_assets()
    run_scene("picnic", assets)
