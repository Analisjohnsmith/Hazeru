# -----------------------------
# CONFIG
# -----------------------------
SCREEN_SCALE = 0.5
FPS = 30

# -----------------------------
# LOAD USER SCENE
# -----------------------------
def load_scene(folder_path):
    folder = Path(folder_path)
    manifest_file = folder / "objects.json"
    if not manifest_file.exists():
        print(f"⚠ No objects.json found in {folder_path}. Creating default scene structure.")
        return {
            "characters": [],
            "companions": [],
            "objects": [],
            "background": pygame.Surface((1920,1080)),
            "scene_adjacency": {}
        }
    with open(manifest_file) as f:
        data = json.load(f)
    # load sprites
    for cat in ["characters","companions","objects"]:
        for obj in data.get(cat, []):
            obj_path = folder / obj["sprite"]
            if obj_path.exists():
                obj["surface"] = pygame.image.load(str(obj_path)).convert_alpha()
                # auto-detect multiple frames if folder exists
                folder_for_frames = obj_path.parent / (obj_path.stem)
                if folder_for_frames.exists() and folder_for_frames.is_dir():
                    obj["frames"] = sorted([pygame.image.load(str(f)).convert_alpha() 
                                            for f in folder_for_frames.iterdir() 
                                            if f.suffix in [".png",".jpg"]])
                else:
                    obj["frames"] = [obj["surface"]]
                obj["frame_index"] = 0
                obj["blink_timer"] = random.randint(60,180)
                obj["dx"] = obj.get("dx",0)
                obj["dy"] = obj.get("dy",0)
    # background
    bg_path = folder / "background.png"
    if bg_path.exists():
        data["background"] = pygame.image.load(str(bg_path)).convert_alpha()
    else:
        data["background"] = pygame.Surface((1920,1080))
        data["background"].fill((150,200,255))
    return data

# -----------------------------
# STATE TRACKING
# -----------------------------
STATE = {
    "triggers_fired": set(),
    "current_scene_folder": None
}

# -----------------------------
# TRIGGER HANDLER
# -----------------------------
def handle_trigger(trigger):
    if trigger in STATE["triggers_fired"]:
        return
    print(f">>> Trigger fired: {trigger}")
    STATE["triggers_fired"].add(trigger)
    # Generic effects for common triggers
    if trigger.lower().startswith("summon"):
        print("✨ Summoning effect (kitten/companion/etc.)")
    elif trigger.lower().startswith("glow"):
        print("🌟 Glow effect triggered")
    elif trigger.lower().startswith("move"):
        print("🏃 Object movement started")
    elif trigger.lower().startswith("scene"):
        print("🔄 Scene switching triggered")

# -----------------------------
# CLICK DETECTION
# -----------------------------
def check_click(pos, scene):
    x, y = pos
    for cat in ["characters","companions","objects"]:
        for obj in scene.get(cat, []):
            rect = obj["frames"][0].get_rect(topleft=(obj["x"]*SCREEN_SCALE,obj["y"]*SCREEN_SCALE))
            if rect.collidepoint(x,y):
                trigger = obj.get("trigger")
                if trigger:
                    handle_trigger(trigger)

# -----------------------------
# ANIMATE COMPANIONS & CHARACTERS
# -----------------------------
def animate_objects(scene):
    for cat in ["characters","companions"]:
        for obj in scene.get(cat, []):
            # Blink / idle animation
            obj["blink_timer"] -= 1
            if obj["blink_timer"] <= 0 and len(obj["frames"])>1:
                obj["frame_index"] = (obj["frame_index"] + 1) % len(obj["frames"])
                obj["blink_timer"] = random.randint(60,180)
            # Move if dx/dy set
            obj["x"] += obj.get("dx",0)
            obj["y"] += obj.get("dy",0)

# -----------------------------
# DRAW SCENE
# -----------------------------
def draw_scene(screen, scene):
    bg_scaled = pygame.transform.scale(scene["background"],
        (int(scene["background"].get_width()*SCREEN_SCALE),
         int(scene["background"].get_height()*SCREEN_SCALE)))
    screen.blit(bg_scaled,(0,0))
    for cat in ["objects","characters","companions"]:
        for obj in scene.get(cat, []):
            frame = obj["frames"][obj["frame_index"]]
            surf_scaled = pygame.transform.scale(frame,
                (int(frame.get_width()*SCREEN_SCALE),
                 int(frame.get_height()*SCREEN_SCALE)))
            screen.blit(surf_scaled,(obj["x"]*SCREEN_SCALE,obj["y"]*SCREEN_SCALE))

# -----------------------------
# MAIN LOOP
# -----------------------------
def run_scene(scene_folder):
    pygame.init()
    STATE["current_scene_folder"] = scene_folder
    scene = load_scene(scene_folder)
    width, height = scene["background"].get_width()*SCREEN_SCALE, scene["background"].get_height()*SCREEN_SCALE
    screen = pygame.display.set_mode((int(width), int(height)))
    pygame.display.set_caption("AuroraOS AIR Adventure")
    clock = pygame.time.Clock()
    running = True
    step = 0

    while running:
        for event in pygame.event.get():
            if event.type==pygame.QUIT:
                running=False
            elif event.type==pygame.MOUSEBUTTONDOWN:
                check_click(event.pos, scene)

        animate_objects(scene)
        draw_scene(screen, scene)
        pygame.display.flip()
        clock.tick(FPS)
        step += 1

        # Demo scene switching after 300 steps if adjacency exists
        if "scene_adjacency" in scene and step==300:
            next_scene = scene["scene_adjacency"].get("next_scene")
            if next_scene:
                print(f"➡ Switching to scene: {next_scene}")
                run_scene(next_scene)
                return

    pygame.quit()

