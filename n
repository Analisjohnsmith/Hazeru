        img = ImageOps.solarize(img, threshold=128)
        return img

class LimeMark:
    @staticmethod
    def process(media_path):
        """Add watermark"""
        img = Image.open(media_path)
        watermark = Image.new("RGBA", img.size)
        watermark_text = "SEI MediaMachine"
        return Image.alpha_composite(img.convert("RGBA"), watermark)

class GlyphCake:
    @staticmethod
    def process(media_path):
        """Apply symbolic compression / pixel shuffle"""
        img = Image.open(media_path)
        arr = np.array(img)
        np.random.shuffle(arr.flat)
        return Image.fromarray(arr)

