import json
from pathlib import Path
import time

# -----------------------------
# CONFIGURATION
# -----------------------------
AIR_FILE = "aurora_world.air"  # Your previously built AIR file
FRAME_DELAY = 0.5  # seconds between “frames” in prototype

# -----------------------------
# LOAD AIR FILE
# -----------------------------
def load_air_file(air_path):
    air_bytes = Path(air_path).read_bytes()
    air_str = air_bytes.decode("utf-8", errors="ignore")

    # Parse Scene Data
    try:
        scene_start = air_str.index("---SCENE_DATA_START---") + len("---SCENE_DATA_START---")
        scene_end = air_str.index("---SCENE_DATA_END---")
        scene_json = air_str[scene_start:scene_end].strip()
        scenes = json.loads(scene_json)
        print("✅ Loaded scene data from AIR file.")
    except Exception as e:
        print("❌ Failed to load scene data:", e)
        scenes = {}
    
    # Parse Assets (stub, for now just names)
    assets = {}
    if "---ASSETS_START---" in air_str and "---ASSETS_END---" in air_str:
        assets_section = air_str.split("---ASSETS_START---")[1].split("---ASSETS_END---")[0]
        for line in assets_section.splitlines():
            if line.startswith("--ASSET:"):
                asset_name = line.replace("--ASSET:", "").replace("--", "").strip()
                assets[asset_name] = f"<{asset_name} bytes>"
        print(f"✅ Found {len(assets)} assets in AIR file.")

    return scenes, assets

# -----------------------------
# SIMPLE RUNTIME DISPLAY LOOP
# -----------------------------
def run_scene(scenes):
    print("\n🌌 Welcome to Aurora AIR World Prototype 🌌\n")
    for scene_id, scene in scenes.items():
        print(f"🎨 Scene: {scene['title']} ({scene['mode']})")
        env = scene['environment']
        print(f"🌄 Environment: {env['biome']} at {env['time_of_day']} with {env['lighting']}")
        print(f"🧍 Characters: {[c['name'] for c in scene['characters']]}")
        print(f"🐾 Companions: {[c['name'] for c in scene['companions']]}")
        print("\nStarting scene loop (CTRL+C to exit)...\n")

        # Prototype “animation loop”
        for i in range(5):  # 5 steps of animation
            for comp in scene['companions']:
                # Simple “movement” simulation
                pos = (i, i*2)  # stub positions
                print(f"{comp['name']} moves to position {pos}")
            time.sleep(FRAME_DELAY)
        print("\n--- End of Scene ---\n")
        time.sleep(1)

# -----------------------------
# MAIN
# -----------------------------
if __name__ == "__main__":
    scenes, assets = load_air_file(AIR_FILE)
    run_scene(scenes)

