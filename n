class SEIPattern:
    """Analyzes media and suggests transformations based on patterns."""
    def __init__(self, sei_memory):
        self.memory = sei_memory

    def analyze_image(self, key):
        """Simple pattern analysis: detect brightness, edges, contrast."""
        import cv2
        import numpy as np

        img = self.memory.get(key)
        if img is None:
            return None

        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        edges = cv2.Canny(gray, 50, 150)
        brightness = np.mean(gray)
        suggestions = []

        if brightness < 80:
            suggestions.append("brighten")
        if np.mean(edges) > 20:
            suggestions.append("blur")
        return suggestions

    def analyze_audio(self, key):
        """Detects loudness and tempo to suggest effects."""
        audio = self.memory.get(key)
        if audio is None:
            return None

        loudness = audio.dBFS
        suggestions = []
        if loudness < -30:
            suggestions.append("amplify")
        if loudness > -5:
            suggestions.append("normalize")
        return suggestions

