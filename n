import cv2
from pydub import AudioSegment
from datetime import datetime

# -----------------------------
# Module 1: SEI Intelligence
# -----------------------------
class SEIIntelligence:
    """Tracks all media states and transformation history."""
    def __init__(self):
        self.media_state = {}      # current media keyed by name
        self.transform_log = []    # history of transformations

    def update(self, key, media, transform=None):
        self.media_state[key] = media
        if transform:
            self.transform_log.append({
                "timestamp": datetime.utcnow().isoformat(),
                "key": key,
                "transform": transform
            })

    def get(self, key):
        return self.media_state.get(key)

    def history(self):
        return self.transform_log

# -----------------------------
# Module 2: Media Loader
# -----------------------------
class MediaLoader:
    """Load images, video, and audio for transformation."""
    def __init__(self):
        self.loaded = {}

    def load_image(self, path, key=None):
        img = cv2.imread(path, cv2.IMREAD_UNCHANGED)
        key = key or path
        self.loaded[key] = img
        return key

    def load_video(self, path, key=None):
        cap = cv2.VideoCapture(path)
        key = key or path
        self.loaded[key] = cap
        return key

    def load_audio(self, path, key=None):
        audio = AudioSegment.from_file(path)
        key = key or path
        self.loaded[key] = audio
        return key

# -----------------------------
# Module 3: Transformations
# -----------------------------
class SEITransform:
    """Apply transformations and record them in SEI Intelligence."""
    def __init__(self, sei_memory):
        self.memory = sei_memory

    def apply_filter(self, key, filter_type="grayscale"):
        media = self.memory.get(key)
        if media is None:
            return None

        # Image transformations
        if isinstance(media, (cv2.UMat, type(cv2.imread("")))):
            if filter_type == "grayscale":
                transformed = cv2.cvtColor(media, cv2.COLOR_BGR2GRAY)
            elif filter_type == "invert":
                transformed = cv2.bitwise_not(media)
            else:
                transformed = media

        # Audio transformations
        elif isinstance(media, AudioSegment):
            if filter_type == "reverse":
                transformed = media.reverse()
            elif filter_type == "speedup":
                transformed = media.speedup(1.5)
            else:
                transformed = media
        else:
            transformed = media

        self.memory.update(key, transformed, transform=filter_type)
        return transformed

# -----------------------------
# Module 4: Interactive Preview
# -----------------------------
class InteractivePreview:
    """Preview images in real-time and interactively."""
    def __init__(self, sei):
        self.sei = sei

    def show_image(self, key):
        img = self.sei.get(key)
        if img is None:
            print(f"No media found for key: {key}")
            return
        cv2.imshow(key, img)
        cv2.waitKey(1)

    def close(self):
        cv2.destroyAllWindows()

# -----------------------------
# REPL Core
# -----------------------------
class MediaREPL:
    """Interactive shell for media manipulation with SEI intelligence."""
    def __init__(self):
        self.sei = SEIIntelligence()
        self.loader = MediaLoader()
        self.transformer = SEITransform(self.sei)
        self.preview = InteractivePreview(self.sei)

    def run(self):
        print("SEI Media REPL — type 'help' for commands")
        while True:
            cmd = input(">> ").strip().split()
            if not cmd:
                continue

            action = cmd[0].lower()
            args = cmd[1:]

            if action == "help":
                print("Commands: load_img, load_audio, filter, preview, history, exit")
            elif action == "load_img" and args:
                key = self.loader.load_image(args[0])
                self.sei.update(key, self.loader.loaded[key])
                print(f"Loaded image as key: {key}")
            elif action == "load_audio" and args:
                key = self.loader.load_audio(args[0])
                print(f"Loaded audio as key: {key}")
            elif action == "filter" and len(args) >= 2:
                key, ftype = args[0], args[1]
                result = self.transformer.apply_filter(key, ftype)
                print(f"Applied {ftype} on {key}")
            elif action == "preview" and args:
                self.preview.show_image(args[0])
            elif action == "history":
                for entry in self.sei.history():
                    print(entry)
            elif action == "exit":
                self.preview.close()
                print("Exiting SEI Media REPL")
                break
            else:
                print("Unknown command or missing arguments")

# -----------------------------
# Entry Point
# -----------------------------
if __name__ == "__main__":
    repl = MediaREPL()
    repl.run()
