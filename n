    audio = memory.get(key)
    if audio is None:
        print("Audio not found")
        return

    import tkinter as tk
    from tkinter import ttk

    def apply_gain(val):
        nonlocal audio
        gain_db = int(val)
        new_audio = audio + gain_db
        memory.update(key, new_audio, transform=f"gain:{gain_db}")
        # Play in separate thread
        threading.Thread(target=play, args=(new_audio,), daemon=True).start()

    root = tk.Tk()
    root.title(f"Audio Live Edit: {key}")
    ttk.Label(root, text="Gain (dB)").pack()
    slider = tk.Scale(root, from_=-20, to=20, orient="horizontal", command=apply_gain, length=400)
    slider.set(0)
    slider.pack()
    root.mainloop()

