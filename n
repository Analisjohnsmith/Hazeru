class SEIIntelligence:
    def __init__(self):
        self.status = "idle"
        self.timestamp = datetime.utcnow().isoformat()
        self.modules = {}

    def load_module(self, name, func):
        """Attach a media processing module"""
        self.modules[name] = func

    def run_module(self, name, data):
        """Run a single module"""
        if name in self.modules:
            return self.modules[name](data)
        else:
            raise ValueError(f"Module '{name}' not loaded")

    def execute_all(self, data):
        """Run all loaded modules sequentially"""
        results = {}
        for name, func in self.modules.items():
            results[name] = func(data)
        return results

# -----------------------------
# Media Machine
# -----------------------------
class MediaMachine:
    def __init__(self):
        self.kernel = SEIIntelligence()

    def add_media_module(self, name, transform_func):
        self.kernel.load_module(name, transform_func)

    def process_media(self, media_input):
        """Process all modules on the input media"""
        return self.kernel.execute_all(media_input)

