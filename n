def live_image_editor(key, memory):
    img = memory.get(key)
    if img is None:
        print("Image not found")
        return

    window = f"Live Edit: {key}"
    cv2.namedWindow(window)

    # Slider callbacks
    def nothing(x): pass
    cv2.createTrackbar("Brightness", window, 100, 200, nothing)
    cv2.createTrackbar("Blur", window, 0, 20, nothing)
    cv2.createTrackbar("Contrast", window, 100, 300, nothing)

    while True:
        bright = cv2.getTrackbarPos("Brightness", window)
        blur_val = cv2.getTrackbarPos("Blur", window)
        contrast = cv2.getTrackbarPos("Contrast", window)

        adjusted = cv2.convertScaleAbs(img, alpha=contrast/100, beta=bright-100)
        if blur_val > 0:
            adjusted = cv2.GaussianBlur(adjusted, (blur_val*2+1, blur_val*2+1), 0)

        cv2.imshow(window, adjusted)
        memory.update(key, adjusted, transform=f"bright:{bright},blur:{blur_val},contrast:{contrast}")

        if cv2.waitKey(1) & 0xFF == 27:  # Esc to exit
            break

    cv2.destroyWindow(window)

