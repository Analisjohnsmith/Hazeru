def export_scene_data(engine_runtime):
    """
    Export all scenes, characters, and companions as JSON bytes.
    """
    scenes_payload = {}
    for scene_id, scene in engine_runtime.scenes.items():
        scene_dict = {
            "id": scene.id,
            "title": scene.title,
            "mode": scene.mode.value,
            "resolution": scene.resolution,
            "environment": {
                "time_of_day": scene.environment.time_of_day.value,
                "lighting": scene.environment.lighting,
                "biome": scene.environment.biome.value,
                "terrain": scene.environment.terrain,
                "mood": scene.environment.mood.value
            },
            "characters": [asdict(c) for c in scene.characters],
            "companions": [asdict(c) for c in scene.companions],
            "art_flags": scene.art_flags
        }
        scenes_payload[scene_id] = scene_dict

    return json.dumps(scenes_payload, indent=2).encode("utf-8")


# -----------------------------
# COLLECT EXTRA ASSETS
# -----------------------------
def collect_assets(folder_path):
    """
    Returns a dictionary of asset_name -> bytes
    """
    assets = {}
    folder = Path(folder_path)
    if folder.exists():
        for file_path in folder.rglob("*"):
            if file_path.is_file():
                assets[file_path.name] = file_path.read_bytes()
    return assets


# -----------------------------
# BUILD AIR FILE
# -----------------------------
def build_air_file(engine_runtime, artwork_path, runtime_path, assets_folder, output_path):
    artwork_bytes = Path(artwork_path).read_bytes()
    runtime_bytes = Path(runtime_path).read_bytes()
    scene_bytes = export_scene_data(engine_runtime)
    assets = collect_assets(assets_folder)

    # Start constructing AIR
    air_bytes = artwork_bytes
    air_bytes += b"\nAURORA_AIR_V1\n"

    # Scene Data
    air_bytes += b"---SCENE_DATA_START---\n"
    air_bytes += scene_bytes
    air_bytes += b"\n---SCENE_DATA_END---\n"

    # Embedded Assets
    air_bytes += b"---ASSETS_START---\n"
    for name, data in assets.items():
        air_bytes += f"--ASSET:{name}--\n".encode("utf-8")
        air_bytes += data + b"\n"
    air_bytes += b"---ASSETS_END---\n"

    # Embedded Runtime
    air_bytes += b"---RUNTIME_START---\n"
    air_bytes += runtime_bytes
    air_bytes += b"\n---RUNTIME_END---\n"

    # End of AIR
    air_bytes += b"---AIR_END---\n"

    Path(output_path).write_bytes(air_bytes)
    print(f"✅ AIR file built successfully: {output_path}")


