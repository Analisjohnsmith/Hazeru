import cv2
import numpy as np
from pydub import AudioSegment
from pydub.playback import play
import threading
import tkinter as tk
from tkinter import ttk

# -----------------------------
# SEI Memory with Undo/Redo
# -----------------------------
class SEIMemory:
    def __init__(self):
        self.store = {}

    def add(self, key, media):
        self.store[key] = {
            "media": media,
            "history": [],
            "redo_stack": []
        }

    def get(self, key):
        return self.store.get(key, {}).get("media")

    def update(self, key, media, transform=None):
        if key not in self.store:
            self.add(key, media)
        else:
            self.store[key]["redo_stack"] = []  # Clear redo on new action
            if transform:
                self.store[key]["history"].append((media.copy() if isinstance(media, np.ndarray) else media, transform))
            self.store[key]["media"] = media

    def undo(self, key):
        if key in self.store and self.store[key]["history"]:
            last_media, last_transform = self.store[key]["history"].pop()
            self.store[key]["redo_stack"].append((self.store[key]["media"], last_transform))
            self.store[key]["media"] = last_media
            return last_transform
        return None

    def redo(self, key):
        if key in self.store and self.store[key]["redo_stack"]:
            next_media, next_transform = self.store[key]["redo_stack"].pop()
            self.store[key]["history"].append((next_media, next_transform))
            self.store[key]["media"] = next_media
            return next_transform
        return None

    def history(self, key):
        return [t[1] for t in self.store.get(key, {}).get("history", [])]

