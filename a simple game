def tag_node(node: Node, label: str) -> Node:
    node.tags.append(label)
    return node

def style_node(node: Node, key: str, val: Any) -> Node:
    node.style[key] = val
    return node

def branch_node(node: Node, value: Any) -> Node:
    child = new_node(value)
    node.kids.append(child)
    return child

def branch_tag_node(node: Node, value: Any, label: str) -> Node:
    child = branch_node(node, value)
    tag_node(child, label)
    return child

def compose_node(node: Node) -> List[Node]:
    result = [node]
    for child in node.kids:
        result.extend(compose_node(child))
    return result

def render_node(node: Node) -> List[Dict[str, Any]]:
    rendered = []
    def traverse(n: Node, depth: int):
        rendered.append({
            "value": n.value,
            "depth": depth,
            "tags": n.tags,
            "style": n.style,
        })
        for child in n.kids:
            traverse(child, depth + 1)
    traverse(node, 0)
    return rendered

def validate_node(node: Node) -> bool:
