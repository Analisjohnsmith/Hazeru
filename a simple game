    # Check invariants
    if not node:
        return False
    # Check for zero_loss_continuity (no orphaned nodes)
    all_connected = True
    def check_connected(n: Node, visited: set):
        visited.add(id(n))
        for child in n.kids:
            if id(child) not in visited:
                check_connected(child, visited)
    visited = set()
    check_connected(node, visited)
    # Ensure all nodes are connected to root
    return len(visited) > 0

