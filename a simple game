        print("\n" + FRACTAL_NATURE_OS["identity"])
        print("Kenji stands between Path A (Beautiful Dream) and Path B (True Soil).")
        print("You influence the world by placing attention. Attention is a finite token resource.\n")

        while self.running:
            action = self.get_input()
            if action == "exit":
                self.running = False
                break

            self.process_action(action)

            # Run one tick if not exiting
            if self.running:
                if not self.tick():
                    break

        # Save on exit
        self.continuity.save(self.world, self.kenji, self.ecology, self.memory, self.discovery)
        print("\n💾 Game saved. Thank you for playing.")

