class WorldSim:
    def __init__(self):
        self.attention = AttentionPool(initial=100)
        self.beauty = {"field_dusk": 1.0, "path_a": 1.0, "path_b": 1.0}
        self.events = []
        self.time = 0
        self.weather_intensity = 0.5
        self.weather_type = IhatovWeatherType.CLEAR
        self.time_of_day = 0.0  # 0-1 normalized
        self.day_length = 600.0

    def tick(self) -> Dict[str, Any]:
        self.time += 1
        self.attention.tick_decay()
        self.time_of_day += 1.0 / self.day_length
        if self.time_of_day > 1.0:
            self.time_of_day -= 1.0

        # Beauty decays unless tended
        for r in self.beauty:
            decay = 0.002 + (0.01 if self.attention.regions[r]["score"] < 5 else 0)
            self.beauty[r] = max(0.0, self.beauty[r] - decay)

        # Weather shifts
        self.weather_intensity += (random.random() - 0.5) * 0.01
        self.weather_intensity = max(0.0, min(1.0, self.weather_intensity))

        # Emergent event chance
        if RNG.random() < 0.02:
            ev = self.spawn_event()
            self.events.append(ev)

        return self.snapshot()

    def apply_player_attention(self, region: str, tokens: float = 5.0) -> float:
        spent = self.attention.spend(region, tokens)
        self.beauty[region] = min(2.0, self.beauty[region] + spent * 0.01)
        return spent

    def spawn_event(self) -> Dict[str, Any]:
        return {
            "id": f"evt_{self.time}_{RNG.randint(0,9999)}",
            "time": self.time,
            "type": RNG.choice(["visitor", "storm", "memory_recall"]),
            "payload": {}
        }

    def snapshot(self) -> Dict[str, Any]:
        return {
            "time": self.time,
            "time_of_day": self.time_of_day,
            "attention": self.attention.snapshot(),
            "beauty": {k: round(v, 3) for k, v in self.beauty.items()},
            "weather_intensity": self.weather_intensity,
            "weather_type": self.weather_type.value if hasattr(self.weather_type, 'value') else 0,
            "events": list(self.events)
        }

