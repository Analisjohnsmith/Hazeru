class AttentionPool:
    def __init__(self, initial: int = 100):
        self.pool = initial
        self.region_weights = {"field_dusk": 0.5, "path_a": 0.3, "path_b": 0.2}
        self.regions = {k: {"score": v * initial} for k, v in self.region_weights.items()}

    def spend(self, region: str, amount: float) -> float:
        if amount <= 0:
            return 0.0
        available = self.pool
        spent = min(available, amount)
        self.pool -= spent
        self.regions[region]["score"] += spent
        return spent

    def gain(self, amount: float) -> float:
        self.pool += amount
        return self.pool

    def tick_decay(self):
        for r in self.regions:
            self.regions[r]["score"] *= 0.995

    def snapshot(self) -> Dict[str, Any]:
        return {
            "pool": self.pool,
            "regions": {r: int(self.regions[r]["score"]) for r in self.regions}
        }

