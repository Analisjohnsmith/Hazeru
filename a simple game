class TimeLoopManager:
    """Equivalent of TimeLoopManager.cs"""
    def __init__(self, loop_duration: float = 1320.0):
        self.loop_duration = loop_duration
        self.current_time = 0.0
        self.on_loop_reset = None

    def update(self, delta_time: float) -> None:
        self.current_time += delta_time
        if self.current_time >= self.loop_duration:
            self.reset_loop()

    def normalized_time(self) -> float:
        return self.current_time / self.loop_duration

    def reset_loop(self) -> None:
        self.current_time = 0.0
        if self.on_loop_reset:
            self.on_loop_reset()

class PlanetOrbit:
    """Equivalent of PlanetOrbit.cs"""
    def __init__(self, star_pos=(0,0,0), semi_major_axis=100, eccentricity=0.1,
                 orbital_period=600, inclination=5, arg_periapsis=0,
                 lon_ascending_node=0, initial_mean_anomaly=0):
        self.star_pos = star_pos
        self.semi_major_axis = semi_major_axis
        self.eccentricity = eccentricity
        self.orbital_period = orbital_period
        self.inclination = inclination
        self.arg_periapsis = arg_periapsis
        self.lon_ascending_node = lon_ascending_node
        self.initial_mean_anomaly = initial_mean_anomaly
        self.position = (semi_major_axis, 0, 0)

    def solve_kepler(self, M: float, e: float, iterations: int = 8) -> float:
        E = M
        for _ in range(iterations):
            f = E - e * math.sin(E) - M
            fp = 1.0 - e * math.cos(E)
            if abs(fp) < 1e-12:
                break
            E -= f / fp
        return E

    def update(self, t: float) -> None:
        n = 2.0 * math.pi / self.orbital_period
        M = self.initial_mean_anomaly + n * t
        E = self.solve_kepler(M, self.eccentricity)
        v = 2.0 * math.atan2(
            math.sqrt(1 + self.eccentricity) * math.sin(E / 2.0),
            math.sqrt(1 - self.eccentricity) * math.cos(E / 2.0)
        )
        r = self.semi_major_axis * (1 - self.eccentricity * math.cos(E))

        # Orbital position
        pos = (r * math.cos(v), 0.0, r * math.sin(v))
        self.position = pos

class GravityWell:
    """Equivalent of GravityWell.cs"""
    def __init__(self, pos=(0,0,0), gravity_constant=6.674e-1, mass=1e7, max_accel=200):
        self.position = pos
        self.gravity_constant = gravity_constant
        self.mass = mass
        self.max_accel = max_accel

    def apply_force(self, body_pos: Tuple[float, float, float]) -> Tuple[float, float, float]:
        dx = self.position[0] - body_pos[0]
        dy = self.position[1] - body_pos[1]
        dz = self.position[2] - body_pos[2]
        dist_sqr = max(dx*dx + dy*dy + dz*dz, 4.0)
        dist = math.sqrt(dist_sqr)
        magnitude = self.gravity_constant * self.mass / dist_sqr
        magnitude = min(magnitude, self.max_accel)
        return (dx / dist * magnitude, dy / dist * magnitude, dz / dist * magnitude)

class ShipController:
    """Equivalent of ShipController.cs"""
    def __init__(self, thrust=25, rotation_speed=70, boost_multiplier=3, max_speed=120):
        self.thrust = thrust
        self.rotation_speed = rotation_speed
        self.boost_multiplier = boost_multiplier
        self.max_speed = max_speed
        self.velocity = (0.0, 0.0, 0.0)
        self.position = (0.0, 0.0, 0.0)
        self.rotation = (0.0, 0.0, 0.0)  # pitch, yaw, roll

    def update(self, inputs: Dict[str, float], delta_time: float) -> None:
        # Rotation
        yaw = inputs.get("mouse_x", 0.0) * self.rotation_speed * delta_time
        pitch = -inputs.get("mouse_y", 0.0) * self.rotation_speed * delta_time
        roll = 0.0
        if inputs.get("roll_left", False):
            roll += self.rotation_speed * delta_time
        if inputs.get("roll_right", False):
            roll -= self.rotation_speed * delta_time

        self.rotation = (self.rotation[0] + pitch, self.rotation[1] + yaw, self.rotation[2] + roll)

        # Thrust
        forward = inputs.get("forward", 0.0)
        strafe = inputs.get("strafe", 0.0)
        up = inputs.get("up", 0.0)
        boost = inputs.get("boost", False)

        # Simple direction
        dir_vec = (forward, up, strafe)
        mag = math.sqrt(dir_vec[0]**2 + dir_vec[1]**2 + dir_vec[2]**2)
        if mag > 0:
            dir_vec = (dir_vec[0]/mag, dir_vec[1]/mag, dir_vec[2]/mag)

        mult = self.boost_multiplier if boost else 1.0
        self.velocity = (
            self.velocity[0] + dir_vec[0] * self.thrust * mult * delta_time,
            self.velocity[1] + dir_vec[1] * self.thrust * mult * delta_time,
            self.velocity[2] + dir_vec[2] * self.thrust * mult * delta_time,
        )

        # Speed limit
        speed = math.sqrt(self.velocity[0]**2 + self.velocity[1]**2 + self.velocity[2]**2)
        if speed > self.max_speed:
            self.velocity = (
                self.velocity[0] / speed * self.max_speed,
                self.velocity[1] / speed * self.max_speed,
                self.velocity[2] / speed * self.max_speed,
            )

        self.position = (
            self.position[0] + self.velocity[0] * delta_time,
            self.position[1] + self.velocity[1] * delta_time,
            self.position[2] + self.velocity[2] * delta_time,
        )

