@dataclass
class MemoryField:
    memory_of_beauty: float = 0.0
    memory_of_suffering: float = 0.0
    memory_of_attention: float = 0.0
    memory_of_kenji_presence: float = 0.0

    def reset(self) -> None:
        self.memory_of_beauty = 0.0
        self.memory_of_suffering = 0.0
        self.memory_of_attention = 0.0
        self.memory_of_kenji_presence = 0.0

    def accumulate(self, ecology: float, suffering: float, attention: float, kenji_alpha: float,
                   rate: float = 0.1, decay: float = 0.05) -> None:
        self.memory_of_beauty += (ecology - self.memory_of_beauty) * rate * 0.01
        self.memory_of_suffering += (suffering - self.memory_of_suffering) * rate * 0.01
        self.memory_of_attention += (attention - self.memory_of_attention) * rate * 0.01
        self.memory_of_kenji_presence += (kenji_alpha - self.memory_of_kenji_presence) * rate * 0.01

        # Natural forgetting
        self.memory_of_beauty *= (1.0 - decay * 0.01)
        self.memory_of_suffering *= (1.0 - decay * 0.01)
        self.memory_of_attention *= (1.0 - decay * 0.01)
        self.memory_of_kenji_presence *= (1.0 - decay * 0.01)

        # Clamp
        self.memory_of_beauty = max(0.0, min(1.0, self.memory_of_beauty))
        self.memory_of_suffering = max(0.0, min(1.0, self.memory_of_suffering))
        self.memory_of_attention = max(0.0, min(1.0, self.memory_of_attention))
        self.memory_of_kenji_presence = max(0.0, min(1.0, self.memory_of_kenji_presence))

