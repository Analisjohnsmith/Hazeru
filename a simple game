        self.data.discoveries = [
            {"id": e.id, "title": e.title, "description": e.description, "revealed": e.revealed}
            for e in discovery.entries
        ]

        with open(self.save_path, "w", encoding="utf-8") as f:
            json.dump(self.data.__dict__, f, indent=2, default=str)

    def load(self) -> Optional[ContinuityData]:
        if not os.path.exists(self.save_path):
            return None

        with open(self.save_path, "r", encoding="utf-8") as f:
            raw = json.load(f)

        data = ContinuityData()
        for k, v in raw.items():
            if hasattr(data, k):
                setattr(data, k, v)
        return data
