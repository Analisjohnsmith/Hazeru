class WeatherEngine:
    def __init__(self):
        self.current_weather = IhatovWeatherType.CLEAR
        self.intensity = 0.0
        self.transition_speed = 0.4

    def update(self, kenji: KenjiAgent, attention: AttentionPool, suffering: float) -> None:
        if kenji.path == KenjiPath.BEAUTIFUL_DREAM:
            target_type = IhatovWeatherType.GENTLE_RAIN
            target_intensity = min(1.0, attention.pool / 100.0)
        elif kenji.path == KenjiPath.TRUE_SOIL:
            target_type = IhatovWeatherType.HEAVY_RAIN
            target_intensity = suffering
        elif kenji.path == KenjiPath.BRIDGE:
            target_type = IhatovWeatherType.MIST
            target_intensity = 0.5 + (attention.pool / 100.0) * 0.5
        else:
            target_type = IhatovWeatherType.STILLNESS
            target_intensity = 0.0

        self.current_weather = target_type
        self.intensity += (target_intensity - self.intensity) * self.transition_speed * 0.01
        self.intensity = max(0.0, min(1.0, self.intensity))

    def snapshot(self) -> Dict[str, Any]:
        return {
            "type": self.current_weather.value if hasattr(self.current_weather, 'value') else 0,
            "type_name": self.current_weather.name if hasattr(self.current_weather, 'name') else "CLEAR",
